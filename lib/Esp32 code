</style></head><body><div class='container'>
<h1>🌱 ESP32 Smart Irrigation Control</h1>
<div id='status' class='status'>Loading...</div>
<h2>🤖 Auto Mode</h2>
<input type='number' id='duration' placeholder='Duration (minutes)' value='25' style='padding:5px;margin:5px;width:100px'><br>
<button class='btn btn-success' onclick='startAuto()'>Start Auto</button>
<button class='btn btn-danger' onclick='stopAuto()'>Stop Auto</button>
<h2>🔧 Manual Control</h2>
<button class='btn' onclick='controlMain("on")'>Main ON</button>
<button class='btn btn-danger' onclick='controlMain("off")'>Main OFF</button>
<h2>💧 Individual Motors</h2>
<div class='motor-grid' id='motorGrid'></div>
<h2>📊 Sensor Data</h2>
<button class='btn' onclick='loadSensors()'>Refresh Sensors</button>
<div id='sensorData'></div>
<h2>📈 System Status</h2>
<button class='btn' onclick='loadSystem()'>Refresh System</button>
<div id='systemData'></div>
</div>
<script>
let motorStates={};
function controlMain(action){
  fetch('/api/mainmotor/'+action,{method:'POST'})
    .then(r=>r.json()).then(d=>{motorStates[0]=action==='on';updateUI();showStatus('Main motor '+action,'success')})
    .catch(e=>showStatus('Error: '+e.message,'error'));
}
// BUG FIX: now calls /api/motor/on or /api/motor/off correctly
function controlMotor(id,action){
  fetch('/api/motor/'+action+'?motor_id='+id,{method:'POST'})
    .then(r=>r.json()).then(d=>{motorStates[id]=action==='on';renderMotorGrid();showStatus('Motor '+id+' '+action,'success')})
    .catch(e=>showStatus('Error: '+e.message,'error'));
}
function startAuto(){
  let duration=document.getElementById('duration').value||25;
  fetch('/api/auto/start',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({duration:parseInt(duration),motors:[1,2,3,4,5,6,7,8]})})
    .then(r=>r.json()).then(d=>{updateUI();showStatus('Auto mode started for '+duration+' minutes','success')})
    .catch(e=>showStatus('Error: '+e.message,'error'));
}
function stopAuto(){
  fetch('/api/auto/stop',{method:'POST'}).then(r=>r.json())
    .then(d=>{updateUI();showStatus('Auto mode stopped','success')})
    .catch(e=>showStatus('Error: '+e.message,'error'));
}
function renderMotorGrid(){
  let grid='';
  for(let i=1;i<=8;i++){
    let on=motorStates[i]||false;
    grid+='<div class="motor-card '+(on?'on':'off')+'">'
      +'<h3>Motor '+i+'</h3><p>'+(on?'🔴 ON':'⚫ OFF')+'</p>'
      +'<button class="btn" onclick="controlMotor('+i+',\'on\')">ON</button>'
      +'<button class="btn btn-danger" onclick="controlMotor('+i+',\'off\')">OFF</button>'
      +'</div>';
  }
  document.getElementById('motorGrid').innerHTML=grid;
}
function updateUI(){
  fetch('/api/system/status').then(r=>r.json()).then(d=>{
    let mode=d.autoMode?'🤖 AUTO':'👤 MANUAL';
    document.getElementById('status').innerHTML='Mode: '+mode
      +' | Main Motor: '+(d.mainMotor=='on'?'🔴 ON':'⚫ OFF')
      +(d.autoTimeRemaining?' | Time: '+d.autoTimeRemaining+'s':'');
    renderMotorGrid();
  }).catch(e=>showStatus('Error updating UI','error'));
}
function loadSensors(){
  fetch('/api/moisture').then(r=>r.json()).then(d=>{
    let html='<h3>Main Motor Moisture: '+d.main_motor.percent+'%</h3>';
    for(let i=1;i<=8;i++){html+='<p>Sensor '+i+': '+d['sensor_'+i].percent+'%</p>';}
    document.getElementById('sensorData').innerHTML=html;
  }).catch(e=>showStatus('Error loading sensors','error'));
}
function loadSystem(){
  fetch('/api/system/status').then(r=>r.json()).then(d=>{
    document.getElementById('systemData').innerHTML=
      '<p>WiFi: '+d.status+'</p>'
      +'<p>Mode: '+(d.autoMode?'Auto':'Manual')+'</p>'
      +'<p>Active Motors: '+d.activeMotors+'/'+d.totalMotors+'</p>'
      +'<p>Avg Moisture: '+d.avgMoisture+'%</p>'
      +'<p>Uptime: '+(d.uptime/1000).toFixed(1)+'s</p>'
      +'<p>Free Heap: '+d.freeHeap+' bytes</p>'
      +(d.autoTimeRemaining?'<p>⏱️ Auto Time Remaining: '+d.autoTimeRemaining+'s</p>':'');
  }).catch(e=>showStatus('Error loading system','error'));
}
function showStatus(msg,type){
  const s=document.getElementById('status');
  s.textContent=msg; s.className='status '+(type==='success'?'success':'error');
  setTimeout(()=>s.className='status',3000);
}
updateUI(); loadSensors(); loadSystem();
</script></body></html>
