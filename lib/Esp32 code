// ─── NVS: Save one motor's settings ──────────────────────────────────────────
void saveMotorSettings(int motorIndex) {
  preferences.begin("irrigation", false);
  String key;

  key = "plant_" + String(motorIndex);
  preferences.putString(key.c_str(), motorPlantNames[motorIndex]);

  key = "thresh_" + String(motorIndex);
  preferences.putInt(key.c_str(), motorMoistureThreshold[motorIndex]);

  key = "dur_" + String(motorIndex);
  preferences.putInt(key.c_str(), motorRunDuration[motorIndex]);

  key = "auto_" + String(motorIndex);
  preferences.putBool(key.c_str(), motorAutoEnabled[motorIndex]);

  preferences.end();
  Serial.println("💾 Settings saved for Motor " + String(motorIndex + 1));
}

// ─── NVS: Load all motor settings ────────────────────────────────────────────
void loadAllMotorSettings() {
  preferences.begin("irrigation", true);

  for (int i = 0; i < NUM_MOTORS; i++) {
    String key;

    key = "plant_" + String(i);
    motorPlantNames[i] = preferences.getString(key.c_str(), "Plant " + String(i + 1));

    key = "thresh_" + String(i);
    motorMoistureThreshold[i] = preferences.getInt(key.c_str(), 40);

    key = "dur_" + String(i);
    motorRunDuration[i] = preferences.getInt(key.c_str(), 15);

    key = "auto_" + String(i);
    motorAutoEnabled[i] = preferences.getBool(key.c_str(), false);

    Serial.println("📋 Motor " + String(i+1) +
                   " | Plant: " + motorPlantNames[i] +
                   " | Threshold: " + String(motorMoistureThreshold[i]) + "%" +
                   " | Duration: " + String(motorRunDuration[i]) + "min" +
                   " | Auto: " + String(motorAutoEnabled[i] ? "ON" : "OFF"));
  }

  preferences.end();
  Serial.println("✅ All motor settings loaded from NVS");
}

// ─── Per-motor auto irrigation ────────────────────────────────────────────────
void checkPerMotorAutoIrrigation() {
  // Skip completely if alarm is running - prevent interference
  if (alarmRunning) return;

  for (int i = 0; i < NUM_MOTORS; i++) {
    if (!motorAutoEnabled[i]) continue;
    if (autoMode) continue;

    if (motorAutoRunning[i]) {
      unsigned long durationMs = (unsigned long)motorRunDuration[i] * 60 * 1000;
      if (millis() - motorStartTime[i] >= durationMs) {
        motorStates[i] = false;
        digitalWrite(MOTOR_PINS[i], LOW);
        motorAutoRunning[i] = false;

        bool anyRunning = false;
        for (int j = 0; j < NUM_MOTORS; j++) {
          if (motorStates[j]) { anyRunning = true; break; }
        }

        if (!anyRunning) {
          motorStates[0] = false;
          digitalWrite(MOTOR_PINS[0], LOW);
        }
        Serial.println("✅ Motor " + String(i) + " auto irrigation completed");
      }
      continue;
    }

    int currentMoisture = (i == 0) ? mainMotorMoisturePercent : moisturePercents[i-1];
    if (currentMoisture < motorMoistureThreshold[i] && !motorStates[i]) {
      motorStates[i] = true;
      digitalWrite(MOTOR_PINS[i], HIGH);
      motorAutoRunning[i] = true;
      motorStartTime[i] = millis();

      motorStates[0] = true;
      digitalWrite(MOTOR_PINS[0], HIGH);

      Serial.println("💧 Motor " + String(i) +
                     " auto started | Plant: " + motorPlantNames[i] +
                     " | Moisture: " + String(currentMoisture) + "%" +
                     " | Threshold: " + String(motorMoistureThreshold[i]) + "%");
    }
  }
}

// ─── Stop all motors ──────────────────────────────────────────────────────────
void stopAllMotors() {
  for (int i = 0; i < NUM_MOTORS; i++) {
    motorStates[i] = false;
    digitalWrite(MOTOR_PINS[i], LOW);
  }
  autoMode = false;
  alarmRunning = false;
  Serial.println("🛑 All motors stopped");
}

// ─── Start irrigation (auto or alarm) ────────────────────────────────────────
void startIrrigation(unsigned long duration, bool* motorSelection, bool isAuto) {
  irrigationStartTime = millis();
  irrigationDuration = duration;

  if (isAuto) {
    autoMode = true;
    for (int i = 0; i < NUM_MOTORS; i++) {
      selectedMotors[i] = motorSelection[i];
    }
  }

  for (int i = 0; i < NUM_MOTORS; i++) {
    if (motorSelection[i]) {
      motorStates[i] = true;
      digitalWrite(MOTOR_PINS[i], HIGH);
      if (MOTOR_PINS[i] == 2) delay(5);
    } else {
      motorStates[i] = false;
      digitalWrite(MOTOR_PINS[i], LOW);
    }
  }

  String mode = isAuto ? "Auto" : "Alarm";
  Serial.println("🚿 " + mode + " Irrigation Started");
}

// ─── Turn all motors ON ───────────────────────────────────────────────────────
void turnAllMotorsOn() {
  autoMode = false;
  for (int i = 0; i < NUM_MOTORS; i++) {
    motorStates[i] = true;
    digitalWrite(MOTOR_PINS[i], HIGH);
  }
  Serial.println("✅ All motors turned ON");
}

// ─── Turn all motors OFF ──────────────────────────────────────────────────────
void turnAllMotorsOff() {
  autoMode = false;
  for (int i = 0; i < NUM_MOTORS; i++) {
    motorStates[i] = false;
    digitalWrite(MOTOR_PINS[i], LOW);
  }
  Serial.println("⚫ All Motors OFF");
}

// ─── Alarm trigger check ──────────────────────────────────────────────────────
void checkAlarmIrrigation() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int currentHour   = timeinfo.tm_hour;
  int currentMinute = timeinfo.tm_min;
  int currentDay    = timeinfo.tm_mday;

  // No minute gate — check every loop pass
  if (alarmEnabled && !alarmRunning && currentDay != lastAlarmTriggerDay) {
    if (currentHour == alarmHour && currentMinute == alarmMinute) {
      Serial.println("⏰ ALARM TRIGGERED at " + String(currentHour) + ":" + String(currentMinute));

      alarmRunning = true;
      alarmStartMillis = millis();
      lastAlarmTriggerDay = currentDay;
      autoMode = false;

      // Turn on selected motors immediately
      Serial.println("🔧 Starting alarm motors...");
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (alarmSelectedMotors[i]) {
          motorStates[i] = true;
          digitalWrite(MOTOR_PINS[i], HIGH);
          if (MOTOR_PINS[i] == 2) delay(5); // GPIO 2 stabilization
          Serial.println("  Motor " + String(i) + " ON (GPIO " + String(MOTOR_PINS[i]) + ")");
        } else {
          motorStates[i] = false;
          digitalWrite(MOTOR_PINS[i], LOW);
        }
      }
      Serial.println("✅ Alarm irrigation started - Duration: " + String(alarmDuration/1000/60) + " minutes");
    }
  }

  // Stop alarm when duration expires
  if (alarmRunning && (millis() - alarmStartMillis >= alarmDuration)) {
    Serial.println("⏰ Alarm duration expired - Stopping irrigation");
    stopAlarmIrrigation();
    Serial.println("✅ Alarm irrigation completed");
  }
}

// ─── Stop alarm irrigation ────────────────────────────────────────────────────
void stopAlarmIrrigation() {
  alarmRunning = false;
  // alarmEnabled stays true so alarm re-arms for tomorrow automatically
  for (int i = 0; i < NUM_MOTORS; i++) {
    motorStates[i] = false;
    digitalWrite(MOTOR_PINS[i], LOW);
  }
  Serial.println("⏰ Alarm irrigation stopped. Re-arms tomorrow.");
}

// ─── WiFi connection watchdog ─────────────────────────────────────────────────
void checkWiFiConnection() {
  static unsigned long lastReconnectAttempt = 0;
  static int reconnectAttempts = 0;
  const unsigned long RECONNECT_INTERVAL = 30000; // 30 seconds (less frequent)
  const int MAX_RECONNECT_ATTEMPTS = 5; // More attempts before reset

  if (millis() - lastWiFiCheck >= WIFI_CHECK_INTERVAL) {
    lastWiFiCheck = millis();

    if (WiFi.status() != WL_CONNECTED) {
      wifiConnected = false;

      // Non-blocking reconnection attempt
      if (millis() - lastReconnectAttempt >= RECONNECT_INTERVAL && reconnectAttempts < MAX_RECONNECT_ATTEMPTS) {
        lastReconnectAttempt = millis();
        reconnectAttempts++;

        Serial.println("❌ WiFi disconnected! Attempt " + String(reconnectAttempts) + "/" + String(MAX_RECONNECT_ATTEMPTS));

        // Gentle reconnect (no blocking)
        WiFi.reconnect();

        // Check connection after delay (non-blocking)
        if (WiFi.status() == WL_CONNECTED) {
          wifiConnected = true;
          reconnectAttempts = 0;
          Serial.println("✅ WiFi Reconnected! IP: " + WiFi.localIP().toString());
        }

        // Only reset WiFi after many failed attempts (no credential reset)
        if (reconnectAttempts >= MAX_RECONNECT_ATTEMPTS) {
          Serial.println("🔄 Max attempts reached, restarting WiFi...");
          WiFi.disconnect();
          delay(500);
          WiFi.begin(); // Try saved credentials first
          reconnectAttempts = 0;
        }
      }
    } else {
      wifiConnected = true;
      reconnectAttempts = 0; // Reset counter on successful connection
    }
  }
}


