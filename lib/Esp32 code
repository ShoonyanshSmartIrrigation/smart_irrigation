// BLE Server Callbacks - Fixed Connection Handling
class MyServerCallbacks : public NimBLEServerCallbacks {
    void onConnect(NimBLEServer* pServer) {
        deviceConnected = true;
        Serial.println("BLE Client Connected! Clients: " + String(pServer->getConnectedCount()));
        // DO NOT restart advertising - this causes the disconnect loop!
    }

    void onDisconnect(NimBLEServer* pServer) {
        deviceConnected = false;
        Serial.println("BLE Client Disconnected. Clients: " + String(pServer->getConnectedCount()));

        // Wait 2 seconds before restarting advertising to prevent rapid restart loops
        Serial.println("Waiting 2 seconds before restarting advertising...");
        delay(2000);

        if (pServer->getConnectedCount() == 0) {
            Serial.println("Restarting advertising...");
            NimBLEDevice::startAdvertising();
            Serial.println("Advertising restarted safely");
        }
    }
};

// UNIFIED API CORE - processes commands from both WiFi HTTP and BLE
String processCommand(String rawCmd) {
    rawCmd.trim();
    rawCmd.toUpperCase();

    JsonDocument doc;
    String response = "";

    // Simple command format: "ON:1", "OFF:1", "ON:ALL", "OFF:ALL", "STATUS"
    if (rawCmd.startsWith("ON:")) {
        String zoneStr = rawCmd.substring(3);
        if (zoneStr == "ALL") {
            turnAllMotorsOn();
            doc["action"] = "ALL_ON";
            doc["status"] = "ok";
        } else {
            int zone = zoneStr.toInt();
            if (zone >= 0 && zone < NUM_MOTORS) {
                autoMode = false;
                motorStates[zone] = true;
                digitalWrite(MOTOR_PINS[zone], HIGH);
                doc["zone"] = zone;
                doc["state"] = "ON";
                doc["status"] = "ok";
            } else {
                doc["status"] = "error";
                doc["message"] = "Invalid zone number";
            }
        }
    }
    else if (rawCmd.startsWith("OFF:")) {
        String zoneStr = rawCmd.substring(4);
        if (zoneStr == "ALL") {
            turnAllMotorsOff();
            doc["action"] = "ALL_OFF";
            doc["status"] = "ok";
        } else {
            int zone = zoneStr.toInt();
            if (zone >= 0 && zone < NUM_MOTORS) {
                autoMode = false;
                motorStates[zone] = false;
                digitalWrite(MOTOR_PINS[zone], LOW);
                doc["zone"] = zone;
                doc["state"] = "OFF";
                doc["status"] = "ok";
            } else {
                doc["status"] = "error";
                doc["message"] = "Invalid zone number";
            }
        }
    }
    else if (rawCmd == "STATUS") {
        JsonArray motors = doc.createNestedArray("motors");
        for (int i = 0; i < NUM_MOTORS; i++) {
            JsonObject motorObj = motors.createNestedObject();
            motorObj["id"] = i;
            motorObj["state"] = motorStates[i] ? "ON" : "OFF";
        }
        doc["autoMode"] = autoMode;
        doc["alarmEnabled"] = alarmEnabled;
        doc["status"] = "ok";
    }
    else {
        doc["status"] = "error";
        doc["message"] = "Unknown command";
    }

    serializeJson(doc, response);
    return response;
}

// BLE Control Characteristic Callback - Safe Design (No processing in callback)
class MyBLEControlCallbacks : public NimBLECharacteristicCallbacks {
    void onWrite(NimBLECharacteristic* pCharacteristic) {
        // ONLY store command - no processing in callback
        String command = pCharacteristic->getValue().c_str();

        if (command.length() > 0) {
            pendingBLECommand = command;
            newBLECommand = true;
            Serial.println("BLE Command received: " + command);
        }
    }
};


