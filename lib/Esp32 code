                      "\"mainMotor\":\"" + String(motorStates[0] ? "on" : "off") + "\","
                                                                                   "\"mainMotorGpio\":" + String(MOTOR_PINS[0]) + ","
                                                                                                                                  "\"totalMotors\":" + String(NUM_MOTORS) + ","
                                                                                                                                                                            "\"activeMotors\":" + String(activeMotors) + ","
                                                                                                                                                                                                                         "\"totalSensors\":" + String(NUM_SENSORS) + ","
                                                                                                                                                                                                                                                                     "\"avgMoisture\":" + String(avgMoisture) + ","
                                                                                                                                                                                                                                                                                                                "\"uptime\":" + String(millis()) + ","
                                                                                                                                                                                                                                                                                                                                                   "\"freeHeap\":" + String(ESP.getFreeHeap()) + ","
                                                                                                                                                                                                                                                                                                                                                                                                 "\"cpuFreq\":" + String(ESP.getCpuFreqMHz()) + ","
                                                                                                                                                                                                                                                                                                                                                                                                                                                "\"autoMode\":" + String(autoMode ? "true" : "false") + ","
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "\"alarmEnabled\":" + String(alarmEnabled ? "true" : "false") + ","
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "\"alarmRunning\":" + String(alarmRunning ? "true" : "false") + ","
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        "\"nextAlarm\":\"" + String(alarmHour) + ":" +
                      String(alarmMinute < 10 ? "0" : "") + String(alarmMinute) + "\"";

        if (autoMode) {
            unsigned long remaining = irrigationDuration - (millis() - irrigationStartTime);
            json += ",\"autoTimeRemaining\":" + String(remaining / 1000);
        }
        if (alarmRunning) {
            unsigned long remaining = alarmDuration - (millis() - alarmStartMillis);
            json += ",\"alarmTimeRemaining\":" + String(remaining / 1000);
        }

        json += ",\"activeMotorsList\":[";
        bool first = true;
        for (int i = 0; i < NUM_MOTORS; i++) {
            if (motorStates[i]) {
                if (!first) json += ",";
                json += (i == 0) ? "\"main\"" : String(i);
                first = false;
            }
        }
        json += "],\"alarmMotors\":[";
        first = true;
        for (int i = 0; i < NUM_MOTORS; i++) {
            if (alarmSelectedMotors[i]) {
                if (!first) json += ",";
                json += (i == 0) ? "\"main\"" : String(i);
                first = false;
            }
        }
        json += "]}";
        sendJsonResponse(json);
    });

    // Auto start
    server.on("/api/auto/start", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) { server.send(200, "text/plain", ""); return; }

        int duration = 25;
        bool motorSelection[NUM_MOTORS];
        for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = true;

        JsonDocument doc;
        DeserializationError error = deserializeJson(doc, server.arg("plain"));

        if (error) {
            Serial.println("🔴 JSON parse error in /api/auto/start: " + String(error.c_str()));
            sendJsonResponse("{\"status\":\"error\",\"message\":\"Invalid JSON\"}");
            return;
        }

        if (doc.containsKey("duration")) {
            duration = doc["duration"];
            if (duration <= 0) duration = 25;
        }

        if (doc.containsKey("motors")) {
            for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = false;
            JsonArray arr = doc["motors"];
            for (int motorId : arr) {
                if (motorId >= 1 && motorId <= NUM_MOTORS) {
                    motorSelection[motorId - 1] = true;
                }
            }
        }

        startIrrigation((unsigned long)duration * 60 * 1000, motorSelection, true);

        JsonDocument responseDoc;
        responseDoc["status"] = "ok";
        responseDoc["autoMode"] = true;
        responseDoc["duration"] = duration;
        JsonArray motorsArr = responseDoc.createNestedArray("motors");
        for (int i = 0; i < NUM_MOTORS; i++) {
            if (motorSelection[i]) motorsArr.add(i + 1);
        }
        String response;
        serializeJson(responseDoc, response);
        sendJsonResponse(response);
        Serial.println("🤖 Auto Mode Started: " + String(duration) + " minutes");
    });

    // Auto stop
    server.on("/api/auto/stop", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) { server.send(200, "text/plain", ""); return; }
        stopAllMotors();
        sendJsonResponse("{\"status\":\"ok\",\"autoMode\":false}");
    });

    // All ON
    server.on("/api/all/on", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) { server.send(200, "text/plain", ""); return; }
        turnAllMotorsOn();
        sendJsonResponse("{\"status\":\"ok\",\"action\":\"all_on\"}");
    });

    // All OFF
    server.on("/api/all/off", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) { server.send(200, "text/plain", ""); return; }
        turnAllMotorsOff();
        sendJsonResponse("{\"status\":\"ok\",\"action\":\"all_off\"}");
    });

    // Alarm set - HTTP_ANY for CORS and browser testing
    server.on("/api/alarm/set", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) {
