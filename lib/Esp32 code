        if (sensorId > 0 && sensorId <= NUM_SENSORS) {
            int idx = sensorId - 1;
            json = "{\"sensor_id\":" + String(sensorId) +
                   ",\"value\":" + String(moistureValues[idx]) +
                   ",\"percent\":" + String(moisturePercents[idx]) + "}";
        } else {
            json = "{\"main_motor\":{\"value\":" + String(mainMotorMoistureValue) +
                   ",\"percent\":" + String(mainMotorMoisturePercent) + "}";
            for (int i = 0; i < NUM_SENSORS; i++) {
                json += ",\"sensor_" + String(i+1) + "\":{\"value\":" +
                        String(moistureValues[i]) + ",\"percent\":" +
                        String(moisturePercents[i]) + "}";
            }
            json += "}";
        }

        // Debug output for Flutter app
        Serial.println("📱 Sending to Flutter: " + json);
        sendJsonResponse(json);
    });

    // System status
    server.on("/api/system/status", HTTP_GET, []() {
        sendCORSHeaders();
        int activeMotors = 0;
