/*
 * ESP32 Smart Irrigation - WiFi Only - Optimized Version
 */

#include <WiFi.h>
#include <WebServer.h>
#include <WiFiManager.h>
#include <time.h>
#include <Preferences.h>

// Constants
const int NUM_MOTORS = 8;
const int MAIN_MOTOR_PIN = 2;
const int MAIN_MOTOR_MOISTURE_PIN = 4;
const int NUM_SENSORS = 8;
const int STATUS_LED_PIN = 13;
const int MOTOR_PINS[] = {25, 26, 18, 19, 27, 22, 23, 5};
const int MOISTURE_SENSOR_PINS[] = {32, 33, 34, 35, 36, 37, 38, 39};
const unsigned long WIFI_CHECK_INTERVAL = 30000;
const unsigned long SLOW_BLINK_INTERVAL = 1000;
const unsigned long FAST_BLINK_INTERVAL = 500;

// NTP Time Configuration
const char* ntpServer = "pool.ntp.org";
const long gmtOffset_sec = 19800;   // IST = UTC +5:30 = 19800 sec
const int daylightOffset_sec = 0;

// Global variables
WiFiManager wifiManager;
WebServer server(80);
Preferences preferences;
bool motorStates[NUM_MOTORS] = {false};
bool mainMotorState = false;
bool selectedMotors[NUM_MOTORS] = {false};
int moistureValues[NUM_SENSORS] = {0};
int moisturePercents[NUM_SENSORS] = {0};
int mainMotorMoistureValue = 0;
int mainMotorMoisturePercent = 0;
unsigned long lastWiFiCheck = 0;
bool wifiConnected = false;
unsigned long statusLedPreviousMillis = 0;
int statusLedState = LOW;

// Auto mode variables
bool autoMode = false;
unsigned long irrigationStartTime = 0;
unsigned long irrigationDuration = 0;

// Alarm mode variables
bool alarmEnabled = false;
int alarmHour = 0;
int alarmMinute = 0;
unsigned long alarmDuration = 0;
unsigned long alarmStartMillis = 0;
bool alarmRunning = false;
bool alarmSelectedMotors[NUM_MOTORS] = {false};
int lastAlarmTriggerDay = -1; // Prevent multiple triggers in same minute

// Per Motor Plant Settings
String motorPlantNames[NUM_MOTORS] = {
        "Plant 1","Plant 2","Plant 3","Plant 4",
        "Plant 5","Plant 6","Plant 7","Plant 8"
};
int motorMoistureThreshold[NUM_MOTORS] = {40,40,40,40,40,40,40};
int motorRunDuration[NUM_MOTORS] = {15,15,15,15,15,15,15,15};
bool motorAutoEnabled[NUM_MOTORS] = {false,false,false,false,false,false,false,false};
unsigned long motorStartTime[NUM_MOTORS] = {0,0,0,0,0,0,0,0};
bool motorAutoRunning[NUM_MOTORS] = {false,false,false,false,false,false,false};

// Forward declarations
void setup();
void loop();

// Helper function for CORS headers
void sendCORSHeaders() {
  server.sendHeader("Access-Control-Allow-Origin", "*");
  server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
  server.sendHeader("Access-Control-Allow-Headers", "Content-Type");
}

// Helper function for JSON responses
void sendJsonResponse(String json) {
  server.send(200, "application/json", json);
}

void saveMotorSettings(int motorIndex) {
  preferences.begin("irrigation", false);
  String key;

  key = "plant_" + String(motorIndex);
  preferences.putString(key.c_str(), motorPlantNames[motorIndex]);

  key = "thresh_" + String(motorIndex);
  preferences.putInt(key.c_str(), motorMoistureThreshold[motorIndex]);

  key = "dur_" + String(motorIndex);
  preferences.putInt(key.c_str(), motorRunDuration[motorIndex]);

  key = "auto_" + String(motorIndex);
  preferences.putBool(key.c_str(), motorAutoEnabled[motorIndex]);

  preferences.end();
  Serial.println("💾 Settings saved for Motor " + String(motorIndex + 1));
}

void loadAllMotorSettings() {
  preferences.begin("irrigation", true);

  for (int i = 0; i < NUM_MOTORS; i++) {
    String key;

    key = "plant_" + String(i);
    motorPlantNames[i] = preferences.getString(
            key.c_str(),
            "Plant " + String(i + 1)
    );

    key = "thresh_" + String(i);
    motorMoistureThreshold[i] = preferences.getInt(key.c_str(), 40);

    key = "dur_" + String(i);
    motorRunDuration[i] = preferences.getInt(key.c_str(), 15);

    key = "auto_" + String(i);
    motorAutoEnabled[i] = preferences.getBool(key.c_str(), false);

    Serial.println("📋 Motor " + String(i+1) +
                   " | Plant: " + motorPlantNames[i] +
                   " | Threshold: " + String(motorMoistureThreshold[i]) + "%" +
                   " | Duration: " + String(motorRunDuration[i]) + "min" +
                   " | Auto: " + String(motorAutoEnabled[i] ? "ON" : "OFF"));
  }

  preferences.end();
  Serial.println("✅ All motor settings loaded from NVS");
}

void checkPerMotorAutoIrrigation() {
  for (int i = 0; i < NUM_MOTORS; i++) {

    // Skip if auto not enabled for this motor
    if (!motorAutoEnabled[i]) continue;

    // Skip if already running in auto mode or alarm mode
    if (autoMode || alarmRunning) continue;

    // If motor is auto running - check if duration completed
    if (motorAutoRunning[i]) {
      unsigned long durationMs =
              (unsigned long)motorRunDuration[i] * 60 * 1000;
      if (millis() - motorStartTime[i] >= durationMs) {
        // Stop this motor
        motorStates[i] = false;
        digitalWrite(MOTOR_PINS[i], LOW);
        motorAutoRunning[i] = false;

        // Stop main motor if no other motors running
        bool anyRunning = false;
        for (int j = 0; j < NUM_MOTORS; j++) {
          if (motorStates[j]) { anyRunning = true; break; }
        }
        if (!anyRunning) {
          mainMotorState = false;
          digitalWrite(MAIN_MOTOR_PIN, LOW);
        }

        Serial.println("✅ Motor " + String(i+1) +
                       " auto irrigation completed");
      }
      continue;
    }

    // Check moisture threshold
    if (moisturePercents[i] < motorMoistureThreshold[i] &&
        !motorStates[i]) {
      // Start this motor
      motorStates[i] = true;
      digitalWrite(MOTOR_PINS[i], HIGH);
      motorAutoRunning[i] = true;
      motorStartTime[i] = millis();

      // Turn on main motor
      mainMotorState = true;
      digitalWrite(MAIN_MOTOR_PIN, HIGH);

      Serial.println("💧 Motor " + String(i+1) +
                     " auto started | Plant: " + motorPlantNames[i] +
                     " | Moisture: " + String(moisturePercents[i]) + "%" +
                     " | Threshold: " + String(motorMoistureThreshold[i]) + "%");
    }
  }
}

// Helper function to stop all motors
void stopAllMotors() {
  mainMotorState = false;
  digitalWrite(MAIN_MOTOR_PIN, LOW);

  for (int i = 0; i < NUM_MOTORS; i++) {
    motorStates[i] = false;
    digitalWrite(MOTOR_PINS[i], LOW);
  }

  autoMode = false;
  Serial.println("All motors stopped");
}

// Helper function to start irrigation
void startIrrigation(unsigned long duration, bool* motorSelection, bool isAuto) {
  irrigationStartTime = millis();
  irrigationDuration = duration;

  if (isAuto) {
    autoMode = true;
    // Reset selected motors
    for (int i = 0; i < NUM_MOTORS; i++) {
      selectedMotors[i] = motorSelection ? motorSelection[i] : true;
    }
  }

  // Always turn ON main motor
  mainMotorState = true;
  digitalWrite(MAIN_MOTOR_PIN, HIGH);
  Serial.println("Main motor ON");

  // Turn ON selected motors
  for (int i = 0; i < NUM_MOTORS; i++) {
    if (selectedMotors[i]) {
      motorStates[i] = true;
      digitalWrite(MOTOR_PINS[i], HIGH);
      Serial.println("Motor " + String(i+1) + " ON");
    }
  }

  if (isAuto) {
    Serial.println("Auto irrigation started for " + String(duration / 60000) + " minutes");
  }
}

// Helper function to turn all motors ON
void turnAllMotorsOn() {
  // Disable auto mode (manual override)
  autoMode = false;

  // Turn ON all individual motors
  for (int i = 0; i < NUM_MOTORS; i++) {
    motorStates[i] = true;
    digitalWrite(MOTOR_PINS[i], HIGH);
  }

  // Turn ON main motor
  mainMotorState = true;
  digitalWrite(MAIN_MOTOR_PIN, HIGH);

  Serial.println("All Motors ON");
}

// Helper function to turn all motors OFF
void turnAllMotorsOff() {
  // Disable auto mode
  autoMode = false;

  // Turn OFF all individual motors
  for (int i = 0; i < NUM_MOTORS; i++) {
    motorStates[i] = false;
    digitalWrite(MOTOR_PINS[i], LOW);
  }

  // Turn OFF main motor
  mainMotorState = false;
  digitalWrite(MAIN_MOTOR_PIN, LOW);

  Serial.println("All Motors OFF");
}

// Alarm-based irrigation check function
void checkAlarmIrrigation() {
  struct tm timeinfo;
  if (getLocalTime(&timeinfo)) {
    int currentHour = timeinfo.tm_hour;
    int currentMinute = timeinfo.tm_min;
    int currentDay = timeinfo.tm_mday;

    if (alarmEnabled && !alarmRunning && currentDay != lastAlarmTriggerDay) {
      if (currentHour == alarmHour && currentMinute == alarmMinute) {
        alarmRunning = true;
        alarmStartMillis = millis();
        lastAlarmTriggerDay = currentDay;

        // Disable auto mode (manual override)
        autoMode = false;

        // TURN ON MAIN MOTOR
        mainMotorState = true;
        digitalWrite(MAIN_MOTOR_PIN, HIGH);

        // TURN ON SELECTED MOTORS
        for (int i = 0; i < NUM_MOTORS; i++) {
          if (alarmSelectedMotors[i]) {
            motorStates[i] = true;
            digitalWrite(MOTOR_PINS[i], HIGH);
          } else {
            motorStates[i] = false;
            digitalWrite(MOTOR_PINS[i], LOW);
          }
        }

        Serial.println("⏰ Alarm Triggered - Irrigation Started");
      }
    }
  }
}

// Stop alarm irrigation function
void stopAlarmIrrigation() {
  alarmRunning = false;
  alarmEnabled = false;

  // TURN OFF ALL MOTORS
  for (int i = 0; i < NUM_MOTORS; i++) {
    motorStates[i] = false;
    digitalWrite(MOTOR_PINS[i], LOW);
  }

  // TURN OFF MAIN MOTOR
  mainMotorState = false;
  digitalWrite(MAIN_MOTOR_PIN, LOW);
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  pinMode(LED_BUILTIN, OUTPUT);
  pinMode(MAIN_MOTOR_PIN, OUTPUT);
  pinMode(STATUS_LED_PIN, OUTPUT);
  digitalWrite(LED_BUILTIN, LOW);
  digitalWrite(MAIN_MOTOR_PIN, LOW);
  digitalWrite(STATUS_LED_PIN, LOW);

  for (int i = 0; i < NUM_MOTORS; i++) {
    pinMode(MOTOR_PINS[i], OUTPUT);
    digitalWrite(MOTOR_PINS[i], LOW);
  }

  for (int i = 0; i < NUM_SENSORS; i++) {
    pinMode(MOISTURE_SENSOR_PINS[i], INPUT);
  }
  pinMode(MAIN_MOTOR_MOISTURE_PIN, INPUT);

  // WiFi Manager enhanced configuration
  wifiManager.setAPCallback([](WiFiManager *myWiFiManager) {
      Serial.println("📡 AP Mode Active: ESP32-Irrigation\n📡 IP: 192.168.4.1");
      Serial.println("⏰ AP timeout: 180 seconds (3 minutes)");
  });

  wifiManager.setSaveConfigCallback([]() {
      Serial.println("✅ WiFi configuration saved");
  });

  // Set WiFi timeout and retry
  wifiManager.setConnectTimeout(30); // 30 seconds connection timeout
  wifiManager.setConfigPortalTimeout(180); // 3 minutes AP timeout

  // Enable auto reconnect
  WiFi.setAutoReconnect(true);
  WiFi.persistent(true);

  // Try to connect with saved credentials first
  if (!wifiManager.autoConnect("ESP32-Irrigation", "12345678")) {
    Serial.println("❌ Failed to connect or hit timeout");
    Serial.println("🔄 Restarting ESP32...");
    ESP.restart();
  }

  // Configure NTP time
  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
  Serial.println("⏰ NTP Time configured for IST");

  if (WiFi.status() == WL_CONNECTED) {
    wifiConnected = true;
    Serial.println(" WiFi Connected!\n IP: " + WiFi.localIP().toString());
  } else {
    Serial.println(" WiFi Connection Failed");
  }

  loadAllMotorSettings();
  setupServer();
  server.begin();
  Serial.println(" HTTP Server Started\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

void loop() {
  server.handleClient();
  checkWiFiConnection();
  // ... (rest of the code remains the same)

  // Check auto mode completion
  if (autoMode && (millis() - irrigationStartTime >= irrigationDuration)) {
    stopAllMotors();
    Serial.println("Auto irrigation completed");
  }

  // Check alarm-based irrigation
  checkAlarmIrrigation();

  // Check per-motor auto irrigation
  checkPerMotorAutoIrrigation();

  // Check alarm completion
  if (alarmRunning && (millis() - alarmStartMillis >= alarmDuration)) {
    stopAlarmIrrigation();
    Serial.println("⏰ Alarm Completed - Motors OFF");
  }

  handleMainMotorLED();
  handleIndividualMotorsLED();
  handleStatusLED();
  readAllMoistureSensors();
  reportMotorStatus();
  debugHTTPRequests();
  delay(10);
}

void checkWiFiConnection() {
  static unsigned long lastReconnectAttempt = 0;
  static int reconnectAttempts = 0;
  const unsigned long RECONNECT_INTERVAL = 10000; // 10 seconds
  const int MAX_RECONNECT_ATTEMPTS = 3;

  if (millis() - lastWiFiCheck >= WIFI_CHECK_INTERVAL) {
    lastWiFiCheck = millis();

    if (WiFi.status() != WL_CONNECTED) {
      wifiConnected = false;

      // Try to reconnect with non-blocking approach
      if (millis() - lastReconnectAttempt >= RECONNECT_INTERVAL && reconnectAttempts < MAX_RECONNECT_ATTEMPTS) {
        lastReconnectAttempt = millis();
        reconnectAttempts++;

        Serial.println("❌ WiFi disconnected! Attempt " + String(reconnectAttempts) + "/" + String(MAX_RECONNECT_ATTEMPTS));

        // Force disconnect first
        WiFi.disconnect();
        delay(100);

        // Try to reconnect
        WiFi.begin();

        // Check if reconnection successful within 5 seconds
        unsigned long reconnectStart = millis();
        while (WiFi.status() != WL_CONNECTED && millis() - reconnectStart < 5000) {
          delay(100);
          Serial.print(".");
        }

        if (WiFi.status() == WL_CONNECTED) {
          wifiConnected = true;
          reconnectAttempts = 0;
          Serial.println("\n✅ WiFi Reconnected! IP: " + WiFi.localIP().toString());
        } else {
          Serial.println("\n❌ Reconnection attempt failed");

          // If max attempts reached, restart WiFiManager
          if (reconnectAttempts >= MAX_RECONNECT_ATTEMPTS) {
            Serial.println("🔄 Max attempts reached, restarting WiFi...");
            WiFi.disconnect();
            delay(1000);
            wifiManager.resetSettings();
            wifiManager.autoConnect("ESP32-Irrigation", "12345678");
            reconnectAttempts = 0;
          }
        }
      }
    } else {
      wifiConnected = true;
      reconnectAttempts = 0; // Reset counter on successful connection
    }
  }
}

void handleStatusLED() {
  unsigned long currentMillis = millis();

  bool anyMotorOn = mainMotorState;
  if (!anyMotorOn) {
    for (int i = 0; i < NUM_MOTORS; i++) {
      if (motorStates[i]) {
        anyMotorOn = true;
        break;
      }
    }
  }

  if (anyMotorOn) {
    digitalWrite(STATUS_LED_PIN, HIGH);
    statusLedState = HIGH;
  }
  else if (WiFi.status() != WL_CONNECTED) {
    if (currentMillis - statusLedPreviousMillis >= FAST_BLINK_INTERVAL) {
      statusLedPreviousMillis = currentMillis;
      statusLedState = !statusLedState;
      digitalWrite(STATUS_LED_PIN, statusLedState);
    }
  }
  else {
    if (currentMillis - statusLedPreviousMillis >= SLOW_BLINK_INTERVAL) {
      statusLedPreviousMillis = currentMillis;
      statusLedState = !statusLedState;
      digitalWrite(STATUS_LED_PIN, statusLedState);
    }
  }
}

void handleMainMotorLED() {
  static bool lastMainMotorState = false;

  if (mainMotorState) {
    digitalWrite(MAIN_MOTOR_PIN, HIGH);
    if (lastMainMotorState != mainMotorState) {
      Serial.println("🔴 Main Motor: ON - GPIO " + String(MAIN_MOTOR_PIN) + " = HIGH (3.3V)");
      lastMainMotorState = mainMotorState;
    }
  } else {
    digitalWrite(MAIN_MOTOR_PIN, LOW);
    if (lastMainMotorState != mainMotorState) {
      Serial.println("⚫ Main Motor: OFF - GPIO " + String(MAIN_MOTOR_PIN) + " = LOW");
      lastMainMotorState = mainMotorState;
    }
  }
}

void handleIndividualMotorsLED() {
  static bool lastMotorStates[NUM_MOTORS] = {false};

  for (int i = 0; i < NUM_MOTORS; i++) {
    if (motorStates[i]) {
      digitalWrite(MOTOR_PINS[i], HIGH);
      if (lastMotorStates[i] != motorStates[i]) {
        Serial.println("Motor " + String(i+1) + " ON - GPIO " + String(MOTOR_PINS[i]));
        lastMotorStates[i] = motorStates[i];
      }
    } else {
      digitalWrite(MOTOR_PINS[i], LOW);
      if (lastMotorStates[i] != motorStates[i]) {
        Serial.println("Motor " + String(i+1) + " OFF - GPIO " + String(MOTOR_PINS[i]));
        lastMotorStates[i] = motorStates[i];
      }
    }
  }
}

void readAllMoistureSensors() {
  static unsigned long lastSensorRead = 0;
  const unsigned long SENSOR_READ_INTERVAL = 2000;

  if (millis() - lastSensorRead >= SENSOR_READ_INTERVAL) {
    lastSensorRead = millis();

    mainMotorMoistureValue = analogRead(MAIN_MOTOR_MOISTURE_PIN);
    mainMotorMoisturePercent = map(constrain(mainMotorMoistureValue, 0, 4095), 0, 4095, 100, 0);

    for (int i = 0; i < NUM_SENSORS; i++) {
      moistureValues[i] = analogRead(MOISTURE_SENSOR_PINS[i]);
      moisturePercents[i] = map(constrain(moistureValues[i], 0, 4095), 0, 4095, 100, 0);
    }
  }
}

void reportMotorStatus() {
  static unsigned long lastMotorReport = 0;
  const unsigned long MOTOR_REPORT_INTERVAL = 5000;

  if (millis() - lastMotorReport >= MOTOR_REPORT_INTERVAL) {
    lastMotorReport = millis();

    int activeMotors = 0;
    for (int i = 0; i < NUM_MOTORS; i++) {
      if (motorStates[i]) activeMotors++;
    }

    Serial.println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    Serial.println("📊 MOTOR STATUS REPORT");
    Serial.println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    Serial.println("Main Motor: " + String(mainMotorState ? "🔴 ON" : "⚫ OFF"));
    String modeStr = "👤 MANUAL";
    if (autoMode) modeStr = "🤖 AUTO";
    else if (alarmRunning) modeStr = "⏰ ALARM";
    Serial.println("Mode: " + modeStr);
    Serial.println("Active Motors: " + String(activeMotors) + "/" + String(NUM_MOTORS));

    if (autoMode) {
      unsigned long remaining = irrigationDuration - (millis() - irrigationStartTime);
      Serial.println("Auto Time Remaining: " + String(remaining / 1000) + "s");
    }

    if (alarmEnabled && !alarmRunning) {
      Serial.println("⏰ Next Alarm: " + String(alarmHour) + ":" + String(alarmMinute < 10 ? "0" : "") + String(alarmMinute));
    }

    if (alarmRunning) {
      unsigned long remaining = alarmDuration - (millis() - alarmStartMillis);
      Serial.println("Alarm Time Remaining: " + String(remaining / 1000) + "s");
    }

    if (activeMotors > 0) {
      Serial.print("Motors ON: ");
      bool first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorStates[i]) {
          if (!first) Serial.print(", ");
          Serial.print(String(i+1));
          first = false;
        }
      }
      Serial.println();
    }

    Serial.println("💧 MOISTURE SENSOR DATA:");
    Serial.println("Main Motor Moisture: " + String(mainMotorMoisturePercent) + "%");
    for (int i = 0; i < NUM_SENSORS; i++) {
      Serial.println("Sensor " + String(i+1) + ": " + String(moisturePercents[i]) + "%");
    }

    Serial.println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
  }
}

void debugHTTPRequests() {
  static unsigned long lastHTTPDebug = 0;
  const unsigned long HTTP_DEBUG_INTERVAL = 10000;

  if (millis() - lastHTTPDebug >= HTTP_DEBUG_INTERVAL) {
    lastHTTPDebug = millis();
    String ip = WiFi.localIP().toString();
    Serial.println("🌐 HTTP Server: Active | Test: http://" + ip + "/test | Main Motor: http://" + ip + "/api/mainmotor/on");

    static bool ledState = false;
    ledState = !ledState;
    digitalWrite(LED_BUILTIN, ledState);
  }
}

void setupServer() {
  // Generic OPTIONS handler for all endpoints
  server.onNotFound([]() {
      if (server.method() == HTTP_OPTIONS) {
        sendCORSHeaders();
        server.send(200, "text/plain", "");
      } else {
        sendCORSHeaders();
        server.send(404, "text/plain", "Not Found");
      }
  });

  // Existing API endpoints (unchanged but with auto mode override)
  server.on("/api/mainmotor/on", HTTP_POST, []() {
      sendCORSHeaders();
      // Auto mode override
      if (autoMode) autoMode = false;
      mainMotorState = true;
      digitalWrite(MAIN_MOTOR_PIN, HIGH);
      Serial.println("🔴 Main Motor ON - GPIO " + String(MAIN_MOTOR_PIN) + " = HIGH");
      sendJsonResponse("{\"status\":\"ok\",\"motor\":\"main\",\"motor_id\":0,\"led\":\"on\"}");
  });

  server.on("/api/mainmotor/off", HTTP_POST, []() {
      sendCORSHeaders();
      // Auto mode override
      if (autoMode) autoMode = false;
      mainMotorState = false;
      digitalWrite(MAIN_MOTOR_PIN, LOW);
      Serial.println("⚫ Main Motor OFF - GPIO " + String(MAIN_MOTOR_PIN) + " = LOW");
      sendJsonResponse("{\"status\":\"ok\",\"motor\":\"main\",\"motor_id\":0,\"led\":\"off\"}");
  });

  server.on("/api/motor/on", HTTP_POST, []() {
      sendCORSHeaders();
      // Auto mode override
      if (autoMode) autoMode = false;
      int motorId = server.arg("motor_id").toInt();
      if (motorId < 1 || motorId > NUM_MOTORS) motorId = 1;
      int motorIndex = motorId - 1;
      motorStates[motorIndex] = true;
      digitalWrite(MOTOR_PINS[motorIndex], HIGH);
      Serial.println("🔴 Motor " + String(motorId) + " ON - GPIO " + String(MOTOR_PINS[motorIndex]) + " = HIGH");
      sendJsonResponse("{\"status\":\"ok\",\"motor_id\":" + String(motorId) + ",\"motor\":\"on\",\"led\":\"on\"}");
  });

  server.on("/api/motor/off", HTTP_POST, []() {
      sendCORSHeaders();
      // Auto mode override
      if (autoMode) autoMode = false;
      int motorId = server.arg("motor_id").toInt();
      if (motorId < 1 || motorId > NUM_MOTORS) motorId = 1;
      int motorIndex = motorId - 1;
      motorStates[motorIndex] = false;
      digitalWrite(MOTOR_PINS[motorIndex], LOW);
      Serial.println("⚫ Motor " + String(motorId) + " OFF - GPIO " + String(MOTOR_PINS[motorIndex]) + " = LOW");
      sendJsonResponse("{\"status\":\"ok\",\"motor_id\":" + String(motorId) + ",\"motor\":\"off\",\"led\":\"off\"}");
  });

  server.on("/api/motor/status", HTTP_GET, []() {
      sendCORSHeaders();
      int motorId = server.arg("motor_id").toInt();
      if (motorId < 1 || motorId > NUM_MOTORS) motorId = 1;
      int motorIndex = motorId - 1;
      String motorStatus = motorStates[motorIndex] ? "on" : "off";
      sendJsonResponse("{\"motor_id\":" + String(motorId) + ",\"motor\":\"" + motorStatus + "\",\"led\":\"" + motorStatus + "\"}");
  });

  server.on("/api/moisture", HTTP_GET, []() {
      sendCORSHeaders();
      int sensorId = server.arg("sensor_id").toInt();
      String json;

      if (sensorId > 0 && sensorId <= NUM_SENSORS) {
        int sensorIndex = sensorId - 1;
        json = "{\"sensor_id\":" + String(sensorId) + ",\"value\":" + String(moistureValues[sensorIndex]) + ",\"percent\":" + String(moisturePercents[sensorIndex]) + "}";
      } else {
        json = "{\"main_motor\":{\"value\":" + String(mainMotorMoistureValue) + ",\"percent\":" + String(mainMotorMoisturePercent) + "}";
        for (int i = 0; i < NUM_SENSORS; i++) {
          json += ",\"sensor_" + String(i+1) + "\":{\"value\":" + String(moistureValues[i]) + ",\"percent\":" + String(moisturePercents[i]) + "}";
        }
