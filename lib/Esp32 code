void initBLE() {
    Serial.println("Initializing BLE...");

    NimBLEDevice::init("ESP32_Irrigation");
    NimBLEDevice::setMTU(128);  // Very safe MTU - maximum compatibility
    NimBLEDevice::setPower(ESP_PWR_LVL_P6);  // Medium power - more stable
    NimBLEDevice::setScanFilterMode(CONFIG_BTDM_SCAN_DUPL_TYPE_DATA_DEVICE);  // Reduce scan duplicates

    Serial.println("BLE Device Name: ESP32_Irrigation");
    Serial.println("MTU Size: 128 bytes (maximum compatibility)");
    Serial.println("Power Level: Medium (P6) - Most stable");

    // Create BLE Server
    pBLEServer = NimBLEDevice::createServer();

    // Register server callbacks for connection handling
    static MyServerCallbacks serverCallbacks;
    pBLEServer->setCallbacks(&serverCallbacks);

    // Create BLE Service
    NimBLEService* pService = pBLEServer->createService(BLE_SERVICE_UUID);

    // NimBLE auto-creates CCCD when NOTIFY property is used
    // Do NOT manually create 2902 descriptor - causes duplicates
    pTelemetryChar = pService->createCharacteristic(
            BLE_TELE_CHAR_UUID,
            NIMBLE_PROPERTY::READ | NIMBLE_PROPERTY::NOTIFY
    );

    pSystemChar = pService->createCharacteristic(
            BLE_SYS_CHAR_UUID,
            NIMBLE_PROPERTY::READ | NIMBLE_PROPERTY::NOTIFY
    );

    // Control Characteristic for commands (WRITE only)
    pControlChar = pService->createCharacteristic(
            BLE_CTRL_CHAR_UUID,
            NIMBLE_PROPERTY::READ | NIMBLE_PROPERTY::WRITE | NIMBLE_PROPERTY::WRITE_NR
    );

    // Set up safe control callback
    static MyBLEControlCallbacks bleControlCallbacks;
    pControlChar->setCallbacks(&bleControlCallbacks);

    // Start the service
    pService->start();

    // Start advertising - Fixed configuration
    NimBLEAdvertising* pAdvertising = NimBLEDevice::getAdvertising();
    pAdvertising->addServiceUUID(BLE_SERVICE_UUID);
    pAdvertising->setMinInterval(160);  // 160 * 0.625ms = 100ms
    pAdvertising->setMaxInterval(320);  // 320 * 0.625ms = 200ms
    pAdvertising->setScanFilter(false, false);  // Allow all connections

    // Device name in scan response only - UUID already in advertisement
    NimBLEAdvertisementData scanResponse;
    scanResponse.setName("ESP32_Irrigation");
    pAdvertising->setScanResponseData(scanResponse);

    Serial.println("Starting BLE advertising...");
    NimBLEDevice::startAdvertising();
    Serial.println("BLE advertising started successfully");

    bleInitialized = true;
    Serial.println("BLE initialized and advertising");
    Serial.println("Device Name: ESP32_Irrigation");
    Serial.println("Service UUID: " + String(BLE_SERVICE_UUID));
}

void handleBLENotifications() {
    // Safe timing - send every 3 seconds (non-blocking)
    if (!bleInitialized || millis() - lastBLENotify < 3000) {
        return;
    }

    lastBLENotify = millis();

    // ONLY send if device connected - prevents BLE stack errors
    if (!deviceConnected || !pBLEServer || !pTelemetryChar) {
        return;
    }

    // Create telemetry JSON using ArduinoJson
    JsonDocument teleDoc;
    teleDoc["uptime"] = millis();
    teleDoc["main_motor"] = mainMotorMoisturePercent;
    JsonArray sensors = teleDoc.createNestedArray("sensors");
    for (int i = 0; i < NUM_SENSORS; i++) {
        sensors.add(moisturePercents[i]);
    }
    JsonArray motors = teleDoc.createNestedArray("motors");
    for (int i = 0; i < NUM_MOTORS; i++) {
        motors.add(motorStates[i] ? 1 : 0);
    }
    String telemetry;
    serializeJson(teleDoc, telemetry);

    // Send telemetry notification
    if (pTelemetryChar) {
        pTelemetryChar->setValue(telemetry.c_str());
        pTelemetryChar->notify();
        Serial.println("BLE Telemetry sent: " + String(telemetry.length()) + " bytes");
    }

    // Create system status JSON using ArduinoJson
    JsonDocument sysDoc;
    sysDoc["autoMode"]    = autoMode;
    sysDoc["alarmEnabled"] = alarmEnabled;
    sysDoc["alarmRunning"] = alarmRunning;
    sysDoc["freeHeap"]    = ESP.getFreeHeap();
    sysDoc["wifiRSSI"]    = WiFi.RSSI();
    String systemStatus;
    serializeJson(sysDoc, systemStatus);

    // Send system status notification
    if (pSystemChar) {
        pSystemChar->setValue(systemStatus.c_str());
        pSystemChar->notify();
        Serial.println("BLE System status sent: " + String(systemStatus.length()) + " bytes");
    }
}