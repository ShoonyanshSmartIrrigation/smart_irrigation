// POST save motor settings
  server.on("/api/motor/settings", HTTP_POST, []() {
      sendCORSHeaders();

      String body = server.arg("plain");

      // Parse motor_id
      int motorId = 1;
      int idIndex = body.indexOf("\"motor_id\":");
      if (idIndex > 0) {
        int start = idIndex + 11;
        int end = body.indexOf(",", start);
        if (end < 0) end = body.indexOf("}", start);
        motorId = body.substring(start, end).toInt();
        motorId = constrain(motorId, 1, NUM_MOTORS);
      }
      int motorIndex = motorId - 1;

      // Parse plant_name
      int nameIndex = body.indexOf("\"plant_name\":\"");
      if (nameIndex > 0) {
        int start = nameIndex + 14;
        int end = body.indexOf("\"", start);
        if (end > start) {
          motorPlantNames[motorIndex] = body.substring(start, end);
        }
      }

      // Parse moisture_threshold
      int threshIndex = body.indexOf("\"moisture_threshold\":");
      if (threshIndex > 0) {
        int start = threshIndex + 21;
        int end = body.indexOf(",", start);
        if (end < 0) end = body.indexOf("}", start);
        int threshold = body.substring(start, end).toInt();
        motorMoistureThreshold[motorIndex] = constrain(threshold, 0, 100);
      }

      // Parse duration
      int durIndex = body.indexOf("\"duration\":");
      if (durIndex > 0) {
        int start = durIndex + 11;
        int end = body.indexOf(",", start);
        if (end < 0) end = body.indexOf("}", start);
        int duration = body.substring(start, end).toInt();
        motorRunDuration[motorIndex] = constrain(duration, 1, 120);
      }

      // Parse auto_enabled
      int autoIndex = body.indexOf("\"auto_enabled\":");
      if (autoIndex > 0) {
        int start = autoIndex + 15;
        String autoStr = body.substring(start, start + 5);
        motorAutoEnabled[motorIndex] = autoStr.indexOf("true") >= 0;
      }

      // Save to NVS permanently
      saveMotorSettings(motorIndex);

      String response = "{\"status\":\"ok\",\"motor_id\":" +
                        String(motorId) +
                        ",\"plant_name\":\"" + motorPlantNames[motorIndex] + "\"" +
                        ",\"moisture_threshold\":" +
                        String(motorMoistureThreshold[motorIndex]) +
                        ",\"duration\":" + String(motorRunDuration[motorIndex]) +
                        ",\"auto_enabled\":" +
                        String(motorAutoEnabled[motorIndex] ? "true" : "false") +
                        "}";
      sendJsonResponse(response);

      Serial.println("⚙️ Motor " + String(motorId) +
                     " settings updated | Plant: " + motorPlantNames[motorIndex] +
                     " | Threshold: " + String(motorMoistureThreshold[motorIndex]) +
                     "% | Duration: " + String(motorRunDuration[motorIndex]) + "min");
