      lastMainMotorState = mainMotorState;
    }
  }
}

void handleIndividualMotorsLED() {
  static bool lastMotorStates[NUM_MOTORS] = {false};

  for (int i = 0; i < NUM_MOTORS; i++) {
    // Check if 3 seconds have passed since motor was turned on
    // Commented out - remove auto-off for manual control
    // if (motorStates[i] && (millis() - motorOnTimes[i] >= LED_DURATION)) {
    //   digitalWrite(MOTOR_PINS[i], LOW); // Turn motor OFF after 3 seconds
    //   motorStates[i] = false; // Update state
    //   if (lastMotorStates[i] != motorStates[i]) {
    //     Serial.println("💡 Motor " + String(i+1) + ": OFF (3 seconds elapsed)");
    //     lastMotorStates[i] = motorStates[i];
    //   }
    // } else if (motorStates[i] && (millis() - motorOnTimes[i] < LED_DURATION)) {
      // Keep motor ON when state is true (no auto-off)
    if (motorStates[i]) {
      digitalWrite(MOTOR_PINS[i], HIGH); // Keep motor ON
      // Only print once when motor turns ON
      if (lastMotorStates[i] != motorStates[i]) {
        Serial.println("🔴 Motor " + String(i+1) + ": ON - GPIO " + String(MOTOR_PINS[i]) + " = HIGH (3.3V)");
        lastMotorStates[i] = motorStates[i];
      }
    } else if (!motorStates[i]) {
      // Ensure motor is OFF when state is false
      digitalWrite(MOTOR_PINS[i], LOW);
      if (lastMotorStates[i] != motorStates[i]) {
        Serial.println("⚫ Motor " + String(i+1) + ": OFF - GPIO " + String(MOTOR_PINS[i]) + " = LOW");
