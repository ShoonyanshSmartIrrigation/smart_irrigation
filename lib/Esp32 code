}
function loadSensors(){
  fetch('/api/moisture').then(r=>r.json()).then(d=>{
    let html='<h3>Main Motor Moisture: '+d.main_motor.percent+'%</h3>';
    for(let i=1;i<=8;i++){html+='<p>Sensor '+i+': '+d['sensor_'+i].percent+'%</p>';}
    document.getElementById('sensorData').innerHTML=html;
  }).catch(e=>showStatus('Error loading sensors','error'));
}
function loadSystem(){
  fetch('/api/system/status').then(r=>r.json()).then(d=>{
    document.getElementById('systemData').innerHTML=
      '<p>WiFi: '+d.status+'</p>'
      +'<p>Mode: '+(d.autoMode?'Auto':'Manual')+'</p>'
      +'<p>Active Motors: '+d.activeMotors+'/'+d.totalMotors+'</p>'
      +'<p>Avg Moisture: '+d.avgMoisture+'%</p>'
      +'<p>Uptime: '+(d.uptime/1000).toFixed(1)+'s</p>'
      +'<p>Free Heap: '+d.freeHeap+' bytes</p>'
      +(d.autoTimeRemaining?'<p>⏱️ Auto Time Remaining: '+d.autoTimeRemaining+'s</p>':'');
  }).catch(e=>showStatus('Error loading system','error'));
}
function showStatus(msg,type){
  const s=document.getElementById('status');
  s.textContent=msg; s.className='status '+(type==='success'?'success':'error');
  setTimeout(()=>s.className='status',3000);
}
updateUI(); loadSensors(); loadSystem();
