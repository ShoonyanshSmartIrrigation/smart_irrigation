    } else {
      digitalWrite(MOTOR_PINS[i], LOW);
      if (lastMotorStates[i] != motorStates[i]) {
        Serial.println("Motor " + String(i+1) + " OFF - GPIO " + String(MOTOR_PINS[i]));
        lastMotorStates[i] = motorStates[i];
      }
    }
  }
}

// ─── Moisture sensor reader ───────────────────────────────────────────────────
void readAllMoistureSensors() {
  static unsigned long lastSensorRead = 0;
  const unsigned long SENSOR_READ_INTERVAL = 500;

  if (millis() - lastSensorRead >= SENSOR_READ_INTERVAL) {
    lastSensorRead = millis();

    // Read main motor moisture sensor
    int mainMoistureRaw = analogRead(MAIN_MOTOR_MOISTURE_PIN);
    mainMotorMoistureValue = mainMoistureRaw;
    float mainVoltage = (mainMoistureRaw * 3.3) / 4095.0;
    if (mainVoltage < 0.771 || mainVoltage > 2.25) {
      mainMotorMoisturePercent = -1; // Sensor open/not present
    } else {
      mainMotorMoisturePercent = constrain(((2.25 - mainVoltage) / (2.25 - 0.771)) * 100, 0, 100);
    }

    // Read individual plant moisture sensors
    for (int i = 0; i < NUM_SENSORS; i++) {
      int moistureRaw = analogRead(MOISTURE_SENSOR_PINS[i]);
      moistureValues[i] = moistureRaw;
      float voltage = (moistureRaw * 3.3) / 4095.0;
      if (voltage < 0.771 || voltage > 2.25) {
        moisturePercents[i] = -1; // Sensor open/not present
      } else {
        moisturePercents[i] = constrain(((2.25 - voltage) / (2.25 - 0.771)) * 100, 0, 100);
      }
    }
  }
}

// ─── Serial motor status report ───────────────────────────────────────────────
void reportMotorStatus() {
  static unsigned long lastMotorReport = 0;
  const unsigned long MOTOR_REPORT_INTERVAL = 5000;

  if (millis() - lastMotorReport >= MOTOR_REPORT_INTERVAL) {
    lastMotorReport = millis();

    int activeMotors = 0;
    for (int i = 0; i < NUM_MOTORS; i++) {
      if (motorStates[i]) activeMotors++;
    }

    Serial.println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    Serial.println("📊 MOTOR STATUS REPORT");
    Serial.println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    Serial.println("Motor 0 (Main): " + String(motorStates[0] ? "🔴 ON" : "⚫ OFF"));

    String modeStr = "👤 MANUAL";
    if (autoMode) modeStr = "🤖 AUTO";
    else if (alarmRunning) modeStr = "⏰ ALARM";
    Serial.println("Mode: " + modeStr);
    Serial.println("Active Motors: " + String(activeMotors) + "/" + String(NUM_MOTORS));

    if (autoMode) {
      unsigned long remaining = irrigationDuration - (millis() - irrigationStartTime);
      Serial.println("Auto Time Remaining: " + String(remaining / 1000) + "s");
    }

    if (alarmEnabled && !alarmRunning) {
      Serial.println("⏰ Next Alarm: " + String(alarmHour) + ":" +
                     String(alarmMinute < 10 ? "0" : "") + String(alarmMinute));
    }

    if (alarmRunning) {
      unsigned long remaining = alarmDuration - (millis() - alarmStartMillis);
      Serial.println("Alarm Time Remaining: " + String(remaining / 1000) + "s");

      // Show which motors should be running vs actually running
      Serial.println("Alarm Motors Status:");
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (alarmSelectedMotors[i]) {
          Serial.println("  Motor " + String(i) + ": " + String(motorStates[i] ? "✅ ON" : "❌ OFF"));
        }
      }
    }

    if (activeMotors > 0) {
      Serial.print("Motors ON: ");
      bool first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorStates[i]) {
          if (!first) Serial.print(", ");
          Serial.print(i == 0 ? "Main" : String(i).c_str());
          first = false;
        }
      }
      Serial.println();
    }

    Serial.println("💧 MOISTURE SENSOR DATA:");
    Serial.println("Main Motor Moisture: " + String(mainMotorMoisturePercent) + "%");
    for (int i = 0; i < NUM_SENSORS; i++) {
      Serial.println("Sensor " + String(i+1) + ": " + String(moisturePercents[i]) + "%");
    }
    Serial.println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
  }
}

