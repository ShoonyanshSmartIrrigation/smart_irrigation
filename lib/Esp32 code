      int minute = 0;
      int duration = 25; // Default 25 minutes
      bool motorSelection[NUM_MOTORS] = {true}; // Default all motors

      // Parse JSON for hour
      int hourIndex = body.indexOf("\"hour\":");
      if (hourIndex > 0) {
        int start = hourIndex + 7;
        int end = body.indexOf(",", start);
        if (end < 0) end = body.indexOf("}", start);
        if (end > start) {
          String hourStr = body.substring(start, end);
          hour = hourStr.toInt();
          hour = constrain(hour, 0, 23); // Validate 0-23
        }
      }

      // Parse JSON for minute
      int minuteIndex = body.indexOf("\"minute\":");
      if (minuteIndex > 0) {
        int start = minuteIndex + 9;
        int end = body.indexOf(",", start);
        if (end < 0) end = body.indexOf("}", start);
        if (end > start) {
          String minuteStr = body.substring(start, end);
          minute = minuteStr.toInt();
          minute = constrain(minute, 0, 59); // Validate 0-59
        }
      }

      // Parse JSON for duration
      int durationIndex = body.indexOf("\"duration\":");
      if (durationIndex > 0) {
        int start = durationIndex + 11;
        int end = body.indexOf(",", start);
        if (end < 0) end = body.indexOf("}", start);
        if (end > start) {
          String durationStr = body.substring(start, end);
          duration = durationStr.toInt();
          if (duration <= 0) duration = 25;
        }
      }

      // Parse motor array
      int motorsIndex = body.indexOf("\"motors\":");
      if (motorsIndex > 0) {
        int start = body.indexOf("[", motorsIndex);
        int end = body.indexOf("]", start);
        if (end > start) {
          String motorsStr = body.substring(start + 1, end);
          motorsStr.replace(" ", "");
          motorsStr.replace("\n", "");

          // Reset selection
          for (int i = 0; i < NUM_MOTORS; i++) {
            motorSelection[i] = false;
          }

          // Parse motor numbers
          int pos = 0;
          while (pos < motorsStr.length()) {
            int comma = motorsStr.indexOf(",", pos);
            if (comma < 0) comma = motorsStr.length();
            String motorStr = motorsStr.substring(pos, comma);
            int motorId = motorStr.toInt();
            if (motorId >= 1 && motorId <= NUM_MOTORS) {
              motorSelection[motorId - 1] = true;
            }
            pos = comma + 1;
          }
        }
      }

      // Store alarm settings
      alarmHour = hour;
      alarmMinute = minute;
      alarmDuration = (unsigned long)duration * 60 * 1000;
      alarmEnabled = true;
