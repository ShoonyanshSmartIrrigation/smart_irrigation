      String json = "{\"motor_id\":" + String(motorId) +
                    ",\"plant_name\":\"" + motorPlantNames[motorId] + "\"" +
                    ",\"moisture_threshold\":" + String(motorMoistureThreshold[motorId]) +
                    ",\"duration\":" + String(motorRunDuration[motorId]) +
                    ",\"auto_enabled\":" + String(motorAutoEnabled[motorId] ? "true" : "false") +
                    ",\"gpio\":" + String(MOTOR_PINS[motorId]) + "}";

      sendJsonResponse(json);
  });

  // POST motor settings
  server.on("/api/motor/settings", HTTP_POST, []() {
      sendCORSHeaders();
      String body = server.arg("plain");

      int motorId = 0;
      int idIndex = body.indexOf("\"motor_id\":");
      if (idIndex > 0) {
        int s = idIndex + 11; int e = body.indexOf(",", s); if (e < 0) e = body.indexOf("}", s);
        motorId = constrain(body.substring(s, e).toInt(), 0, 8);
      }

      int nameIndex = body.indexOf("\"plant_name\":\"");
      if (nameIndex > 0) {
        int s = nameIndex + 14; int e = body.indexOf("\"", s);
        if (e > s) motorPlantNames[motorId] = body.substring(s, e);
      }

      int threshIndex = body.indexOf("\"moisture_threshold\":");
      if (threshIndex > 0) {
        int s = threshIndex + 21; int e = body.indexOf(",", s); if (e < 0) e = body.indexOf("}", s);
        motorMoistureThreshold[motorId] = constrain(body.substring(s, e).toInt(), 0, 100);
      }

      int durIndex = body.indexOf("\"duration\":");
      if (durIndex > 0) {
        int s = durIndex + 11; int e = body.indexOf(",", s); if (e < 0) e = body.indexOf("}", s);
        motorRunDuration[motorId] = constrain(body.substring(s, e).toInt(), 1, 120);
      }

      int autoIndex = body.indexOf("\"auto_enabled\":");
      if (autoIndex > 0) {
        motorAutoEnabled[motorId] = body.substring(autoIndex + 15, autoIndex + 20).indexOf("true") >= 0;
      }

      saveMotorSettings(motorId);

      sendJsonResponse("{\"status\":\"ok\",\"motor_id\":" + String(motorId) +
                       ",\"plant_name\":\"" + motorPlantNames[motorId] + "\"" +
                       ",\"moisture_threshold\":" + String(motorMoistureThreshold[motorId]) +
                       ",\"duration\":" + String(motorRunDuration[motorId]) +
                       ",\"auto_enabled\":" + String(motorAutoEnabled[motorId] ? "true" : "false") + "}");

      Serial.println("⚙️ Motor " + String(motorId) + " settings updated | Plant: " +
                     motorPlantNames[motorId] + " | Threshold: " + String(motorMoistureThreshold[motorId]) +
                     "% | Duration: " + String(motorRunDuration[motorId]) + "min");
  });

  // Test / debug page
  // BUG FIX: controlMotor() in the JS was calling /api/motor/on for both ON and OFF actions.
  // Fixed to call the correct endpoint based on the action parameter.
