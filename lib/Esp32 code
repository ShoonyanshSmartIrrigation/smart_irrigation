        bool first = true;
        for (int i = 0; i < NUM_MOTORS; i++) {
            if (motorSelection[i]) {
                if (!first) response += ",";
                response += String(i+1); first = false;
            }
        }
        response += "]}";
        sendJsonResponse(response);
        Serial.println("⏰ Alarm Set: " + String(hour) + ":" + String(minute) + " for " + String(duration) + " minutes");
    });

    // Alarm stop - HTTP_ANY for CORS support
    server.on("/api/alarm/stop", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) {
            server.send(200, "text/plain", "");
