            return;
        }

        int hour = 0, minute = 0, duration = 25;
        bool motorSelection[NUM_MOTORS];
        for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = true;

        if (server.method() == HTTP_POST) {
            JsonDocument doc;
            DeserializationError error = deserializeJson(doc, server.arg("plain"));

            if (error) {
                Serial.println("🔴 JSON parse error in /api/alarm/set: " + String(error.c_str()));
                sendJsonResponse("{\"status\":\"error\",\"message\":\"Invalid JSON\"}");
                return;
            }

            if (doc.containsKey("hour"))
                hour = constrain((int)doc["hour"], 0, 23);
            if (doc.containsKey("minute"))
                minute = constrain((int)doc["minute"], 0, 59);
            if (doc.containsKey("duration")) {
                duration = doc["duration"];
                if (duration <= 0) duration = 25;
            }
            if (doc.containsKey("motors")) {
                for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = false;
                JsonArray arr = doc["motors"];
                for (int motorId : arr) {
                    if (motorId >= 1 && motorId <= NUM_MOTORS)
                        motorSelection[motorId - 1] = true;
                }
            }
        } else if (server.method() == HTTP_GET) {
            // Handle GET with query params for browser testing
            hour = constrain(server.arg("hour").toInt(), 0, 23);
            minute = constrain(server.arg("minute").toInt(), 0, 59);
            duration = server.arg("duration").toInt();
            if (duration <= 0) duration = 25;

            String motors = server.arg("motors");
            if (motors.length() > 0) {
                for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = false;
                int motorNum = 0;
                int start = 0;
                for (int i = 0; i <= motors.length(); i++) {
                    if (i == motors.length() || motors.charAt(i) == ',') {
                        if (i > start) {
                            motorNum = motors.substring(start, i).toInt();
                            if (motorNum >= 1 && motorNum <= NUM_MOTORS) {
                                motorSelection[motorNum - 1] = true;
                            }
                        }
                        start = i + 1;
                    }
                }
            }
        }

        alarmHour = hour; alarmMinute = minute;
        alarmDuration = (unsigned long)duration * 60 * 1000;
        alarmEnabled = true; alarmRunning = false; lastAlarmTriggerDay = -1;
        for (int i = 0; i < NUM_MOTORS; i++) alarmSelectedMotors[i] = motorSelection[i];

        String response = "{\"status\":\"ok\",\"alarm\":\"set\",\"hour\":" + String(hour) +
