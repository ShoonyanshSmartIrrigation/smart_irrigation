/*
 * ESP32 Smart Irrigation - WiFi Only Version
 * When motor ON → LED blinks
 * When motor OFF → LED stops
 * Features: WiFi Web Server Control Only
 */

#include <WiFi.h>
#include <WebServer.h>

const char* ssid = "Airtel_kris_8137";
const char* password = "air31225";

WebServer server(80);

// Motor and Sensor Configuration
const int NUM_MOTORS = 8;  // Individual motors
const int MAIN_MOTOR_PIN = 2;  // Main motor control
const int NUM_SENSORS = 8;

// Individual Motor Pins - using safe GPIO pins
const int MOTOR_PINS[NUM_MOTORS] = {25, 26, 18, 19, 27, 22, 23, 5};

// Moisture Sensor Pins
const int MOISTURE_SENSOR_PINS[NUM_SENSORS] = {36, 37, 38, 39, 34, 35, 32, 33};

// Motor States
bool motorStates[NUM_MOTORS] = {false};
bool mainMotorState = false;
unsigned long motorOnTimes[NUM_MOTORS] = {0};
unsigned long mainMotorOnTime = 0;
const unsigned long LED_DURATION = 3000; // 3 seconds in milliseconds

// Moisture Sensor Values
int moistureValues[NUM_SENSORS] = {0};
int moisturePercents[NUM_SENSORS] = {0};

void setup() {
  Serial.begin(115200);
  delay(2000);

  // Initialize built-in LED for debugging
  pinMode(LED_BUILTIN, OUTPUT);
  digitalWrite(LED_BUILTIN, LOW);

  Serial.println("🚀 ESP32 Starting...");

  // Initialize Main Motor
  Serial.println("🔧 Configuring Main Motor on GPIO " + String(MAIN_MOTOR_PIN));
  pinMode(MAIN_MOTOR_PIN, OUTPUT);
  digitalWrite(MAIN_MOTOR_PIN, LOW);
  Serial.println("✅ Main Motor GPIO " + String(MAIN_MOTOR_PIN) + " configured");

  // Initialize Individual Motor Pins
  Serial.println("🔧 Configuring Individual Motors...");
  for (int i = 0; i < NUM_MOTORS; i++) {
    pinMode(MOTOR_PINS[i], OUTPUT);
    digitalWrite(MOTOR_PINS[i], LOW);
    Serial.println("   Motor " + String(i+1) + ": GPIO " + String(MOTOR_PINS[i]) + " OK");
  }

  // Initialize Moisture Sensors
  Serial.println("🌱 Configuring Moisture Sensors...");
  for (int i = 0; i < NUM_SENSORS; i++) {
    pinMode(MOISTURE_SENSOR_PINS[i], INPUT);
    Serial.println("   Sensor " + String(i+1) + ": GPIO " + String(MOISTURE_SENSOR_PINS[i]) + " OK");
  }

  Serial.println("✅ All GPIO Configuration Complete!");
  Serial.println("📡 Connecting to WiFi...");

  // Connect to WiFi
  Serial.print("Connecting to WiFi: ");
  Serial.println(ssid);

  WiFi.begin(ssid, password);

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 30) {
    delay(1000);
    Serial.print(".");
    attempts++;

    // Try to read moisture sensors while connecting
    if (attempts % 5 == 0) {
      Serial.println("\n🌱 Reading sensors during WiFi setup...");
      readAllMoistureSensors();
    }
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✅ WiFi Connected!");
    Serial.print("IP Address: ");
    Serial.println(WiFi.localIP());

    // Start moisture sensor readings immediately after WiFi connects
    Serial.println("🌱 Starting moisture sensor readings...");
    readAllMoistureSensors();
  } else {
    Serial.println("\n❌ WiFi Failed - Starting AP Mode");
    WiFi.softAP("ESP32-Irrigation", "12345678");
    Serial.print("AP IP: ");
    Serial.println(WiFi.softAPIP());

    // Start moisture sensor readings even in AP mode
    Serial.println("🌱 Starting moisture sensor readings in AP mode...");
    readAllMoistureSensors();
  }

  // Setup web server endpoints
  setupServer();

  server.begin();
  Serial.println("🚀 HTTP Server Started!");
  Serial.println("📱 Ready for Android App Connection");
  Serial.println("🔍 Test URL: http://" + WiFi.localIP().toString() + "/api/system/status");
}

void loop() {
  server.handleClient();

  // Handle LED states for main motor and individual motors (3-second timer)
  handleMainMotorLED();
  handleIndividualMotorsLED();

  // Read all moisture sensors every 2 seconds
  readAllMoistureSensors();

  // Report motor status every 5 seconds
  reportMotorStatus();

  // Debug: Show HTTP requests every 10 seconds
  debugHTTPRequests();
}

