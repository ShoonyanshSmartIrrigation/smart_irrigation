  //   }
  // } else if (mainMotorState && (millis() - mainMotorOnTime < LED_DURATION)) {
    // Keep main motor ON when state is true (no auto-off)
  if (mainMotorState) {
    digitalWrite(MAIN_MOTOR_PIN, HIGH); // Keep main motor ON
