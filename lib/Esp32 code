  server.on("/api/system/status", HTTP_GET, []() {
      sendCORSHeaders();
      int activeMotors = 0;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorStates[i]) activeMotors++;
      }

      int avgMoisture = 0;
      for (int i = 0; i < NUM_SENSORS; i++) {
        avgMoisture += moisturePercents[i];
      }
