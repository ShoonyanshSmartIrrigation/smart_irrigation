        int motorId = server.arg("motor_id").toInt();
        motorId = constrain(motorId, 0, 8);

        String json = "{\"motor_id\":" + String(motorId) +
                      ",\"plant_name\":\"" + motorPlantNames[motorId] + "\"" +
