      json += "\"alarmHour\":" + String(alarmHour) + ",";
      json += "\"alarmMinute\":" + String(alarmMinute) + ",";
      json += "\"alarmDuration\":" + String(alarmDuration / 60000) + ",";
      json += "\"alarmTimeRemaining\":" + String(alarmRunning ? (alarmDuration - (millis() - alarmStartMillis)) / 1000 : 0) + ",";
      json += "\"alarmSelectedMotors\":[";

      bool first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (alarmSelectedMotors[i]) {
          if (!first) json += ",";
          json += String(i);
          first = false;
        }
      }
      json += "]}";

      sendJsonResponse(json);
