      for (int i = 0; i < NUM_MOTORS; i++) {
        alarmSelectedMotors[i] = motorSelection[i];
      }

      String response = "{\"status\":\"ok\",\"alarm\":\"set\",\"hour\":" + String(hour) + ",\"minute\":" + String(minute) + ",\"duration\":" + String(duration) + ",\"motors\":[";
