  // Only print when state actually changes
  static bool lastMainMotorState = false;

  // Check if 3 seconds have passed since main motor was turned on
  // Commented out - remove auto-off for manual control
  // if (mainMotorState && (millis() - mainMotorOnTime >= LED_DURATION)) {
  //   digitalWrite(MAIN_MOTOR_PIN, LOW); // Turn main motor OFF after 3 seconds
  //   mainMotorState = false; // Update state
  //   if (lastMainMotorState != mainMotorState) {
