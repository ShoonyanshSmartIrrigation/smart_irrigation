// ─── Non-blocking quick reconnect test ────────────────────────────────────────
// BUG FIX: Was accidentally defined inside checkWiFiConnection() due to missing braces above.
// BUG FIX: Removed blocking while() loop — replaced with a non-blocking check
//          to prevent freezing the web server for up to 3 seconds.
void quickConnectionTest() {
    static unsigned long lastTest = 0;
    static unsigned long reconnectStarted = 0;
    static bool reconnecting = false;

    if (!reconnecting && millis() - lastTest >= 5000) {
        lastTest = millis();
        if (WiFi.status() != WL_CONNECTED) {
            Serial.println("🔍 Testing connection...");
            WiFi.reconnect();
            reconnectStarted = millis();
            reconnecting = true;
        }
    }

    // Non-blocking: check result on next loop iteration(s)
    if (reconnecting && millis() - reconnectStarted >= 3000) {
        reconnecting = false;
        if (WiFi.status() == WL_CONNECTED) {
            Serial.println("✅ Quick reconnection successful!");
        }
    }
}

// ─── Status LED handler ───────────────────────────────────────────────────────
// BUG FIX: Loop now starts from i=0 (was redundantly checking motorStates[0] twice).
void handleStatusLED() {
    unsigned long currentMillis = millis();

    bool anyMotorOn = false;
    for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorStates[i]) { anyMotorOn = true; break; }
    }

    if (anyMotorOn) {
        digitalWrite(STATUS_LED_PIN, HIGH);
        statusLedState = HIGH;
    } else if (WiFi.status() != WL_CONNECTED) {
        if (currentMillis - statusLedPreviousMillis >= FAST_BLINK_INTERVAL) {
            statusLedPreviousMillis = currentMillis;
            statusLedState = !statusLedState;
            digitalWrite(STATUS_LED_PIN, statusLedState);
        }
    } else {
        if (currentMillis - statusLedPreviousMillis >= SLOW_BLINK_INTERVAL) {
            statusLedPreviousMillis = currentMillis;
            statusLedState = !statusLedState;
            digitalWrite(STATUS_LED_PIN, statusLedState);
        }
    }
}

