      String json = "{\"status\":\"ok\",\"mainMotor\":\"" + String(mainMotorState ? "on" : "off") + "\",\"mainMotorGpio\":" + String(MAIN_MOTOR_PIN) + ",\"totalMotors\":" + String(NUM_MOTORS) + ",\"activeMotors\":" + String(activeMotors) + ",\"totalSensors\":" + String(NUM_SENSORS) + ",\"avgMoisture\":" + String(avgMoisture) + ",\"uptime\":" + String(millis()) + ",\"freeHeap\":" + String(ESP.getFreeHeap()) + ",\"cpuFreq\":" + String(ESP.getCpuFreqMHz()) + ",\"autoMode\":" + String(autoMode ? "true" : "false") + ",\"alarmEnabled\":" + String(alarmEnabled ? "true" : "false") + ",\"alarmRunning\":" + String(alarmRunning ? "true" : "false") + ",\"nextAlarm\":\"" + String(alarmHour) + ":" + String(alarmMinute < 10 ? "0" : "") + String(alarmMinute) + "\"";

      if (autoMode) {
        unsigned long remaining = irrigationDuration - (millis() - irrigationStartTime);
        json += ",\"autoTimeRemaining\":" + String(remaining / 1000);
      }

      if (alarmRunning) {
        unsigned long remaining = alarmDuration - (millis() - alarmStartMillis);
        json += ",\"alarmTimeRemaining\":" + String(remaining / 1000);
      }

      // Active motors list
      json += ",\"activeMotorsList\":[";
      bool first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorStates[i]) {
          if (!first) json += ",";
          json += String(i + 1);
          first = false;
        }
      }
      json += "]";

      // Alarm selected motors list
      json += ",\"alarmMotors\":[";
      first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (alarmSelectedMotors[i]) {
          if (!first) json += ",";
          json += String(i + 1);
          first = false;
        }
      }
      json += "]";

      json += "}";
      sendJsonResponse(json);
  });

  // NEW Auto Mode APIs
  server.on("/api/auto/start", HTTP_POST, []() {
      sendCORSHeaders();

      String body = server.arg("plain");
      int duration = 25; // Default 25 minutes
      bool motorSelection[NUM_MOTORS] = {true}; // Default all motors

      // Simple JSON parsing for duration
      int durationIndex = body.indexOf("\"duration\":");
      if (durationIndex > 0) {
        int start = durationIndex + 11;
        int end = body.indexOf(",", start);
        if (end < 0) end = body.indexOf("}", start);
        if (end > start) {
          String durationStr = body.substring(start, end);
          duration = durationStr.toInt();
          if (duration <= 0) duration = 25;
        }
      }

      // Parse motor array
      int motorsIndex = body.indexOf("\"motors\":");
      if (motorsIndex > 0) {
        int start = body.indexOf("[", motorsIndex);
        int end = body.indexOf("]", start);
        if (end > start) {
          String motorsStr = body.substring(start + 1, end);
          motorsStr.replace(" ", "");
          motorsStr.replace("\n", "");

          // Reset selection
          for (int i = 0; i < NUM_MOTORS; i++) {
            motorSelection[i] = false;
          }

          // Parse motor numbers
          int pos = 0;
          while (pos < motorsStr.length()) {
            int comma = motorsStr.indexOf(",", pos);
            if (comma < 0) comma = motorsStr.length();
            String motorStr = motorsStr.substring(pos, comma);
            int motorId = motorStr.toInt();
            if (motorId >= 1 && motorId <= NUM_MOTORS) {
              motorSelection[motorId - 1] = true;
            }
            pos = comma + 1;
          }
        }
      }

      // Start auto irrigation
      unsigned long durationMs = (unsigned long)duration * 60 * 1000;
      startIrrigation(durationMs, motorSelection, true);

      String response = "{\"status\":\"ok\",\"autoMode\":true,\"duration\":" + String(duration) + ",\"motors\":[";
      bool first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorSelection[i]) {
          if (!first) response += ",";
          response += String(i+1);
          first = false;
        }
      }
      response += "]}";
      sendJsonResponse(response);
  });

