        if (doc.containsKey("duration"))
            motorRunDuration[motorId] = constrain((int)doc["duration"], 1, 120);
        if (doc.containsKey("auto_enabled"))
            motorAutoEnabled[motorId] = (bool)doc["auto_enabled"];

        saveMotorSettings(motorId);

        JsonDocument responseDoc;
        responseDoc["status"] = "ok";
        responseDoc["motor_id"] = motorId;
        responseDoc["plant_name"] = motorPlantNames[motorId];
        responseDoc["moisture_threshold"] = motorMoistureThreshold[motorId];
        responseDoc["duration"] = motorRunDuration[motorId];
        responseDoc["auto_enabled"] = motorAutoEnabled[motorId];
        String response;
        serializeJson(responseDoc, response);
        sendJsonResponse(response);

        Serial.println("⚙️ Motor " + String(motorId) + " settings updated | Plant: " +
                       motorPlantNames[motorId] + " | Threshold: " + String(motorMoistureThreshold[motorId]) +
                       "% | Duration: " + String(motorRunDuration[motorId]) + "min");
    });

