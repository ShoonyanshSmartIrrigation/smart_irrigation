// ─── setup() ─────────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  delay(1000);

  pinMode(LED_BUILTIN, OUTPUT);
  pinMode(STATUS_LED_PIN, OUTPUT);
  digitalWrite(LED_BUILTIN, LOW);
  digitalWrite(STATUS_LED_PIN, LOW);

  Serial.println("🔧 Initializing Motors...");
  for (int i = 0; i < NUM_MOTORS; i++) {
    Serial.println("  Motor " + String(i) + " → GPIO " + String(MOTOR_PINS[i]));
    if (MOTOR_PINS[i] == 2) {
      Serial.println("    ⚠️ GPIO 2 detected - using LED pin for Motor 4");
      delay(10);
    }
    pinMode(MOTOR_PINS[i], OUTPUT);
    digitalWrite(MOTOR_PINS[i], LOW);
  }
  Serial.println("✅ Motors initialized");

  for (int i = 0; i < NUM_SENSORS; i++) {
    pinMode(MOISTURE_SENSOR_PINS[i], INPUT);
  }
  pinMode(MAIN_MOTOR_MOISTURE_PIN, INPUT);

  wifiManager.setAPCallback([](WiFiManager *myWiFiManager) {
      Serial.println("📡 AP Mode Active: ESP32-Irrigation\n📡 IP: 192.168.4.1");
  });

  wifiManager.setSaveConfigCallback([]() {
      Serial.println("✅ WiFi configuration saved");
  });

  wifiManager.setConnectTimeout(10);
  wifiManager.setConfigPortalTimeout(120);
  wifiManager.setDebugOutput(true);
  wifiManager.setCleanConnect(false);

  WiFi.setAutoReconnect(true);
  WiFi.persistent(true);

  Serial.println("🔍 Fast WiFi connection starting...");
  Serial.println("📡 Looking for saved credentials...");

  if (!wifiManager.autoConnect("ESP32-Irrigation", "12345678")) {
    Serial.println("❌ Failed to connect or hit timeout");
    Serial.println("🔄 Restarting ESP32...");
    ESP.restart();
  } else {
    Serial.println("✅ WiFi Manager connected successfully!");
    Serial.println("📡 Checking WiFi status...");

    // Verify connection
    if (WiFi.status() == WL_CONNECTED) {
      Serial.println("✅ WiFi connection verified!");
      Serial.println("📡 SSID: " + WiFi.SSID());
      Serial.println("📡 IP: " + WiFi.localIP().toString());
      Serial.println("📡 RSSI: " + String(WiFi.RSSI()) + " dBm");
    } else {
      Serial.println("❌ WiFi status check failed!");
    }
  }

  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
  Serial.println("⏰ NTP Time configured for IST");

  wifiConnected = (WiFi.status() == WL_CONNECTED);
  if (wifiConnected) {
    Serial.println("✅ WiFi Connected!\n IP: " + WiFi.localIP().toString());
  } else {
    Serial.println("❌ WiFi Connection Failed");
  }

  loadAllMotorSettings();
  setupServer();
  server.begin();
  Serial.println("🌐 HTTP Server Started\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ─── loop() ──────────────────────────────────────────────────────────────────
void loop() {
  server.handleClient();
  checkWiFiConnection();
  quickConnectionTest();
  debugWiFiStatus();

  // Auto mode completion check
  if (autoMode && (millis() - irrigationStartTime >= irrigationDuration)) {
    stopAllMotors();
    Serial.println("✅ Auto irrigation completed");
  }

  checkAlarmIrrigation();
  checkPerMotorAutoIrrigation();
  handleStatusLED();
  handleMainMotorLED();
  handleIndividualMotorsLED();
  readAllMoistureSensors();
  reportMotorStatus();
  debugHTTPRequests();
}

// ─── setupServer() ────────────────────────────────────────────────────────────
void setupServer() {
  // Generic OPTIONS / 404 handler
  server.onNotFound([]() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) {
        server.send(200, "text/plain", "");
      } else {
        server.send(404, "text/plain", "Not Found");
      }
  });

  // Main motor ON
  server.on("/api/mainmotor/on", HTTP_ANY, []() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) {
        server.send(200, "text/plain", "");
        return;
      }
      autoMode = false;
      motorStates[0] = true;
      digitalWrite(MOTOR_PINS[0], HIGH);
      sendJsonResponse("{\"status\":\"ok\",\"motor\":\"main\",\"motor_id\":0,\"led\":\"on\"}");
  });

  // Main motor OFF
  server.on("/api/mainmotor/off", HTTP_ANY, []() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) {
        server.send(200, "text/plain", "");
        return;
      }
      autoMode = false;
      motorStates[0] = false;
      digitalWrite(MOTOR_PINS[0], LOW);
      sendJsonResponse("{\"status\":\"ok\",\"motor\":\"main\",\"motor_id\":0,\"led\":\"off\"}");
  });

  // Individual motor ON
  server.on("/api/motor/on", HTTP_ANY, []() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) {
        server.send(200, "text/plain", "");
        return;
      }
      autoMode = false;
      int motorId = constrain(server.arg("motor_id").toInt(), 0, 8);
      motorStates[motorId] = true;
      digitalWrite(MOTOR_PINS[motorId], HIGH);
      sendJsonResponse("{\"status\":\"ok\",\"motor_id\":" + String(motorId) + ",\"state\":\"on\"}");
  });

  // Individual motor OFF
  // BUG FIX: Test page JS was calling /api/motor/on for both ON and OFF.
  // The endpoint itself was correct; fixed test page JS below.
  server.on("/api/motor/off", HTTP_ANY, []() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) {
        server.send(200, "text/plain", "");
        return;
      }
      autoMode = false;
      int motorId = constrain(server.arg("motor_id").toInt(), 0, 8);
      motorStates[motorId] = false;
      digitalWrite(MOTOR_PINS[motorId], LOW);
      sendJsonResponse("{\"status\":\"ok\",\"motor_id\":" + String(motorId) + ",\"state\":\"off\"}");
  });

  // Motor status
  server.on("/api/motor/status", HTTP_GET, []() {
      sendCORSHeaders();
      int motorId = constrain(server.arg("motor_id").toInt(), 0, 8);
      String s = motorStates[motorId] ? "on" : "off";
      sendJsonResponse("{\"motor_id\":" + String(motorId) + ",\"motor\":\"" + s + "\",\"led\":\"" + s + "\"}");
  });

  // Moisture data - Reversed mapping: 0V=Dry(0%), 3.3V=Wet(100%)
  server.on("/api/moisture", HTTP_GET, []() {
      sendCORSHeaders();
      int sensorId = server.arg("sensor_id").toInt();
      String json;

      if (sensorId > 0 && sensorId <= NUM_SENSORS) {
        int idx = sensorId - 1;
        json = "{\"sensor_id\":" + String(sensorId) +
               ",\"value\":" + String(moistureValues[idx]) +
               ",\"percent\":" + String(moisturePercents[idx]) + "}";
      } else {
        json = "{\"main_motor\":{\"value\":" + String(mainMotorMoistureValue) +
               ",\"percent\":" + String(mainMotorMoisturePercent) + "}";
        for (int i = 0; i < NUM_SENSORS; i++) {
          json += ",\"sensor_" + String(i+1) + "\":{\"value\":" +
                  String(moistureValues[i]) + ",\"percent\":" +
                  String(moisturePercents[i]) + "}";
        }
        json += "}";
      }
      sendJsonResponse(json);
  });

  // System status
  server.on("/api/system/status", HTTP_GET, []() {
      sendCORSHeaders();
      int activeMotors = 0;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorStates[i]) activeMotors++;
      }

      int avgMoisture = 0;
      for (int i = 0; i < NUM_SENSORS; i++) avgMoisture += moisturePercents[i];
      avgMoisture /= NUM_SENSORS;

      String json = "{\"status\":\"ok\","
                    "\"mainMotor\":\"" + String(motorStates[0] ? "on" : "off") + "\","
                                                                                 "\"mainMotorGpio\":" + String(MOTOR_PINS[0]) + ","
                                                                                                                                "\"totalMotors\":" + String(NUM_MOTORS) + ","
                                                                                                                                                                          "\"activeMotors\":" + String(activeMotors) + ","
                                                                                                                                                                                                                       "\"totalSensors\":" + String(NUM_SENSORS) + ","
                                                                                                                                                                                                                                                                   "\"avgMoisture\":" + String(avgMoisture) + ","
                                                                                                                                                                                                                                                                                                              "\"uptime\":" + String(millis()) + ","
                                                                                                                                                                                                                                                                                                                                                 "\"freeHeap\":" + String(ESP.getFreeHeap()) + ","
                                                                                                                                                                                                                                                                                                                                                                                               "\"cpuFreq\":" + String(ESP.getCpuFreqMHz()) + ","
                                                                                                                                                                                                                                                                                                                                                                                                                                              "\"autoMode\":" + String(autoMode ? "true" : "false") + ","
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "\"alarmEnabled\":" + String(alarmEnabled ? "true" : "false") + ","
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "\"alarmRunning\":" + String(alarmRunning ? "true" : "false") + ","
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "\"nextAlarm\":\"" + String(alarmHour) + ":" +
                    String(alarmMinute < 10 ? "0" : "") + String(alarmMinute) + "\"";

      if (autoMode) {
        unsigned long remaining = irrigationDuration - (millis() - irrigationStartTime);
        json += ",\"autoTimeRemaining\":" + String(remaining / 1000);
      }
      if (alarmRunning) {
        unsigned long remaining = alarmDuration - (millis() - alarmStartMillis);
        json += ",\"alarmTimeRemaining\":" + String(remaining / 1000);
      }

      json += ",\"activeMotorsList\":[";
      bool first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorStates[i]) {
          if (!first) json += ",";
          json += (i == 0) ? "\"main\"" : String(i);
          first = false;
        }
      }
      json += "],\"alarmMotors\":[";
      first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (alarmSelectedMotors[i]) {
          if (!first) json += ",";
          json += (i == 0) ? "\"main\"" : String(i);
          first = false;
        }
      }
      json += "]}";
      sendJsonResponse(json);
  });

  // Auto start
  server.on("/api/auto/start", HTTP_ANY, []() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) { server.send(200, "text/plain", ""); return; }

      String body = server.arg("plain");
      int duration = 25;
      bool motorSelection[NUM_MOTORS] = {false};
      for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = true; // default all

      int durationIndex = body.indexOf("\"duration\":");
      if (durationIndex > 0) {
        int s = durationIndex + 11;
        int e = body.indexOf(",", s); if (e < 0) e = body.indexOf("}", s);
        duration = body.substring(s, e).toInt();
        if (duration <= 0) duration = 25;
      }

      int motorsIndex = body.indexOf("\"motors\":");
      if (motorsIndex > 0) {
        int s = body.indexOf("[", motorsIndex);
        int e = body.indexOf("]", s);
        if (e > s) {
          String motorsStr = body.substring(s + 1, e);
          motorsStr.replace(" ", ""); motorsStr.replace("\n", "");
          for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = false;
          int pos = 0;
          while (pos < (int)motorsStr.length()) {
            int comma = motorsStr.indexOf(",", pos);
            if (comma < 0) comma = motorsStr.length();
            int motorId = motorsStr.substring(pos, comma).toInt();
            if (motorId >= 1 && motorId <= NUM_MOTORS) motorSelection[motorId - 1] = true;
            pos = comma + 1;
          }
        }
      }

      startIrrigation((unsigned long)duration * 60 * 1000, motorSelection, true);

      String response = "{\"status\":\"ok\",\"autoMode\":true,\"duration\":" + String(duration) + ",\"motors\":[";
      bool first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorSelection[i]) {
          if (!first) response += ",";
          response += String(i+1);
          first = false;
        }
      }
      response += "]}";
      sendJsonResponse(response);
      Serial.println("🤖 Auto Mode Started: " + String(duration) + " minutes");
  });

  // Auto stop
  server.on("/api/auto/stop", HTTP_ANY, []() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) { server.send(200, "text/plain", ""); return; }
      stopAllMotors();
      sendJsonResponse("{\"status\":\"ok\",\"autoMode\":false}");
  });

  // All ON
  server.on("/api/all/on", HTTP_ANY, []() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) { server.send(200, "text/plain", ""); return; }
      turnAllMotorsOn();
      sendJsonResponse("{\"status\":\"ok\",\"action\":\"all_on\"}");
  });

  // All OFF
  server.on("/api/all/off", HTTP_ANY, []() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) { server.send(200, "text/plain", ""); return; }
      turnAllMotorsOff();
      sendJsonResponse("{\"status\":\"ok\",\"action\":\"all_off\"}");
  });

  // Alarm set - HTTP_ANY for CORS and browser testing
  server.on("/api/alarm/set", HTTP_ANY, []() {
      sendCORSHeaders();
      if (server.method() == HTTP_OPTIONS) {
        server.send(200, "text/plain", "");
        return;
      }

      int hour = 0, minute = 0, duration = 25;
      bool motorSelection[NUM_MOTORS];
      for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = true;

      if (server.method() == HTTP_POST) {
        // Handle POST with JSON body (existing logic)
        String body = server.arg("plain");

        int hourIndex = body.indexOf("\"hour\":");
        if (hourIndex > 0) {
          int s = hourIndex + 7; int e = body.indexOf(",", s); if (e < 0) e = body.indexOf("}", s);
          hour = constrain(body.substring(s, e).toInt(), 0, 23);
        }
        int minuteIndex = body.indexOf("\"minute\":");
        if (minuteIndex > 0) {
          int s = minuteIndex + 9; int e = body.indexOf(",", s); if (e < 0) e = body.indexOf("}", s);
          minute = constrain(body.substring(s, e).toInt(), 0, 59);
        }
        int durationIndex = body.indexOf("\"duration\":");
        if (durationIndex > 0) {
          int s = durationIndex + 11; int e = body.indexOf(",", s); if (e < 0) e = body.indexOf("}", s);
          duration = body.substring(s, e).toInt();
          if (duration <= 0) duration = 25;
        }

        int motorsIndex = body.indexOf("\"motors\":");
        if (motorsIndex > 0) {
          int s = body.indexOf("[", motorsIndex); int e = body.indexOf("]", s);
          if (e > s) {
            String motorsStr = body.substring(s + 1, e);
            motorsStr.replace(" ", ""); motorsStr.replace("\n", "");
            for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = false;
            int pos = 0;
            while (pos < (int)motorsStr.length()) {
              int comma = motorsStr.indexOf(",", pos); if (comma < 0) comma = motorsStr.length();
              int motorId = motorsStr.substring(pos, comma).toInt();
              if (motorId >= 1 && motorId <= NUM_MOTORS) motorSelection[motorId - 1] = true;
              pos = comma + 1;
            }
          }
        }
      } else if (server.method() == HTTP_GET) {
        // Handle GET with query params for browser testing
        hour = constrain(server.arg("hour").toInt(), 0, 23);
        minute = constrain(server.arg("minute").toInt(), 0, 59);
        duration = server.arg("duration").toInt();
        if (duration <= 0) duration = 25;

        String motors = server.arg("motors");
        if (motors.length() > 0) {
          for (int i = 0; i < NUM_MOTORS; i++) motorSelection[i] = false;
          int motorNum = 0;
          int start = 0;
          for (int i = 0; i <= motors.length(); i++) {
            if (i == motors.length() || motors.charAt(i) == ',') {
              if (i > start) {
                motorNum = motors.substring(start, i).toInt();
                if (motorNum >= 1 && motorNum <= NUM_MOTORS) {
                  motorSelection[motorNum - 1] = true;
                }
              }
              start = i + 1;
            }
          }
        }
      }

      alarmHour = hour; alarmMinute = minute;
      alarmDuration = (unsigned long)duration * 60 * 1000;
      alarmEnabled = true; alarmRunning = false; lastAlarmTriggerDay = -1;
      for (int i = 0; i < NUM_MOTORS; i++) alarmSelectedMotors[i] = motorSelection[i];

      String response = "{\"status\":\"ok\",\"alarm\":\"set\",\"hour\":" + String(hour) +
                        ",\"minute\":" + String(minute) + ",\"duration\":" + String(duration) + ",\"motors\":[";
      bool first = true;
      for (int i = 0; i < NUM_MOTORS; i++) {
        if (motorSelection[i]) {
          if (!first) response += ",";
          response += String(i+1); first = false;
        }
      }
      response += "]}";
      sendJsonResponse(response);
      Serial.println("⏰ Alarm Set: " + String(hour) + ":" + String(minute) + " for " + String(duration) + " minutes");
  });

  // Alarm stop - HTTP_ANY for CORS support
  server.on("/api/alarm/stop", HTTP_ANY, []() {
