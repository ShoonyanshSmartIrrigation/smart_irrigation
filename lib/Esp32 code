}

// ─── loop() ──────────────────────────────────────────────────────────────────
void loop() {
    server.handleClient();
    checkWiFiConnection();
    quickConnectionTest();
    debugWiFiStatus();

    // Process BLE commands (safe design - outside callback)
    if (newBLECommand && pendingBLECommand.length() > 0) {
        String response = processCommand(pendingBLECommand);
        bleResponseBuffer = response;
        pendingBLECommand = "";
        newBLECommand = false;
        Serial.println("BLE Command processed: " + response);
    }

    // Auto mode completion check
    if (autoMode && (millis() - irrigationStartTime >= irrigationDuration)) {
        stopAllMotors();
        Serial.println("✅ Auto irrigation completed");
    }

    checkAlarmIrrigation();
    checkPerMotorAutoIrrigation();
    handleStatusLED();
    handleMainMotorLED();
    handleIndividualMotorsLED();
    readAllMoistureSensors();
    reportMotorStatus();

    // Handle BLE notifications (safe telemetry only)
    handleBLENotifications();
    debugHTTPRequests();
}

// ─── setupServer() ────────────────────────────────────────────────────────────
void setupServer() {
    // Generic OPTIONS / 404 handler
    server.onNotFound([]() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) {
            server.send(200, "text/plain", "");
        } else {
            server.send(404, "text/plain", "Not Found");
        }
    });

    // Main motor ON - Using unified API
    server.on("/api/mainmotor/on", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) {
            server.send(200, "text/plain", "");
            return;
        }
        String response = processCommand("ON:0");
        sendJsonResponse(response);
    });

    // Main motor OFF - Using unified API
    server.on("/api/mainmotor/off", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) {
            server.send(200, "text/plain", "");
            return;
        }
        String response = processCommand("OFF:0");
        sendJsonResponse(response);
    });

    // Individual motor ON - Using unified API
    server.on("/api/motor/on", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) {
            server.send(200, "text/plain", "");
            return;
        }
        int motorId = constrain(server.arg("motor_id").toInt(), 0, 8);
        String response = processCommand("ON:" + String(motorId));
        sendJsonResponse(response);
    });

    // Individual motor OFF - Using unified API
    server.on("/api/motor/off", HTTP_ANY, []() {
        sendCORSHeaders();
        if (server.method() == HTTP_OPTIONS) {
            server.send(200, "text/plain", "");
            return;
        }
        int motorId = constrain(server.arg("motor_id").toInt(), 0, 8);
        String response = processCommand("OFF:" + String(motorId));
        sendJsonResponse(response);
    });

    // Motor status
    server.on("/api/motor/status", HTTP_GET, []() {
        sendCORSHeaders();
        int motorId = constrain(server.arg("motor_id").toInt(), 0, 8);
        String s = motorStates[motorId] ? "on" : "off";
        sendJsonResponse("{\"motor_id\":" + String(motorId) + ",\"motor\":\"" + s + "\",\"led\":\"" + s + "\"}");
    });

    // Moisture data - Reversed mapping: 0V=Dry(0%), 3.3V=Wet(100%)
    server.on("/api/moisture", HTTP_GET, []() {
