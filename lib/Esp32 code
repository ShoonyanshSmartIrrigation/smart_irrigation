    wifiConnected = (WiFi.status() == WL_CONNECTED);
    if (wifiConnected) {
        Serial.println("✅ WiFi Connected!\n IP: " + WiFi.localIP().toString());
    } else {
        Serial.println("❌ WiFi Connection Failed");
    }

    loadAllMotorSettings();
    setupServer();
    server.begin();
    Serial.println(" HTTP Server Started\n");

    // BluetoothSerial removed - using NimBLE for all communication
    Serial.println("✅ Using NimBLE for all BLE communication");

