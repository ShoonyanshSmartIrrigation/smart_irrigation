}

void debugHTTPRequests() {
  static unsigned long lastHTTPDebug = 0;
  const unsigned long HTTP_DEBUG_INTERVAL = 10000; // Debug every 10 seconds

  if (millis() - lastHTTPDebug >= HTTP_DEBUG_INTERVAL) {
    Serial.println("🌐 HTTP Server Status: Active");
    Serial.println("🔍 Test URL: http://" + WiFi.localIP().toString() + "/test");
    Serial.println("🔍 Echo URL: http://" + WiFi.localIP().toString() + "/echo");
    Serial.println("📱 Main Motor ON URL: http://" + WiFi.localIP().toString() + "/api/mainmotor/on");
    Serial.println("📱 Motor 1 ON URL: http://" + WiFi.localIP().toString() + "/api/motor/on?motor_id=1");
    lastHTTPDebug = millis();
  }

  // Blink LED to show ESP32 is alive
  static unsigned long lastBlink = 0;
  if (millis() - lastBlink >= 2000) { // Blink every 2 seconds
    static bool ledState = false;
    ledState = !ledState;
    digitalWrite(LED_BUILTIN, ledState);
    lastBlink = millis();
  }
}

void reportMotorStatus() {
  static unsigned long lastMotorReport = 0;
  const unsigned long MOTOR_REPORT_INTERVAL = 5000; // Report every 5 seconds

  if (millis() - lastMotorReport >= MOTOR_REPORT_INTERVAL) {
    Serial.println("🔧 MOTOR STATUS REPORT:");

    // Main motor status
    Serial.print("🔴 Main Motor (GPIO " + String(MAIN_MOTOR_PIN) + "): ");
    Serial.println(mainMotorState ? "ON" : "OFF");

    // Individual motors status
    for (int i = 0; i < NUM_MOTORS; i++) {
      Serial.print("🔧 Motor " + String(i+1) + " (GPIO " + String(MOTOR_PINS[i]) + "): ");
      Serial.println(motorStates[i] ? "ON" : "OFF");
    }
    Serial.println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    lastMotorReport = millis();
  }
}

void readAllMoistureSensors() {
  static unsigned long lastMoistureRead = 0;
  const unsigned long MOISTURE_READ_INTERVAL = 2000; // Read every 2 seconds

  if (millis() - lastMoistureRead >= MOISTURE_READ_INTERVAL) {
    for (int i = 0; i < NUM_SENSORS; i++) {
      // Read analog value (0-4095 for ESP32 ADC)
      moistureValues[i] = analogRead(MOISTURE_SENSOR_PINS[i]);

      // Convert to percentage (inverted - higher value = more water)
      // Typical range: Air (dry) = 3000+, Water (wet) = 1000-
      moisturePercents[i] = map(moistureValues[i], 1000, 3000, 100, 0);
      moisturePercents[i] = constrain(moisturePercents[i], 0, 100);

      Serial.print("🌱 Sensor " + String(i+1) + " (GPIO " + String(MOISTURE_SENSOR_PINS[i]) + "): ");
      Serial.print(moisturePercents[i]);
      Serial.println("%");
    }
    Serial.println("---");
    lastMoistureRead = millis();
  }
}

void setupServer() {
  // Global CORS headers for all responses
  server.on("/api/cors", HTTP_OPTIONS, []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type, Authorization");
    server.send(200, "text/plain", "");
  });

  // Request logging middleware
  server.onNotFound([]() {
    String method = server.method() == HTTP_GET ? "GET" : "POST";
    String body = server.method() == HTTP_POST ? server.arg("plain") : "";
    Serial.println("🌐 HTTP Request: " + method + " " + server.uri());
    if (body.length() > 0) {
      Serial.println("📄 Body: " + body);
    }
    Serial.println("🔍 Headers: " + server.header("Content-Type"));
    server.send(404, "text/plain", "Not Found");
  });

  // Test endpoint
  server.on("/test", HTTP_GET, []() {
    Serial.println("🌐 HTTP Request: GET /test");
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type, Authorization");

    String response = "{\"status\":\"ok\",\"message\":\"ESP32 Web Server is Working!\",\"uptime\":" + String(millis()) + "}";
    server.send(200, "application/json", response);
  });

  // Simple echo endpoint for testing
  server.on("/echo", HTTP_GET, []() {
    Serial.println("🌐 HTTP Request: GET /echo");
    Serial.println("📄 Client IP: " + server.client().remoteIP().toString());
    Serial.println("🔍 Headers received: " + server.headers());

    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type, Authorization");

    String response = "{\"echo\":\"ESP32 received your request\",\"timestamp\":" + String(millis()) + ",\"client_ip\":\"" + server.client().remoteIP().toString() + "\"}";
    server.send(200, "application/json", response);
  });

  server.on("/echo", HTTP_POST, []() {
    Serial.println("🌐 HTTP Request: POST /echo");
    Serial.println("📄 Client IP: " + server.client().remoteIP().toString());
    String body = server.arg("plain");
    Serial.println("📄 Body received: " + body);

    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type, Authorization");

    String response = "{\"echo\":\"ESP32 received your POST\",\"body\":\"" + body + "\",\"timestamp\":" + String(millis()) + "}";
    server.send(200, "application/json", response);
  });

  // Root endpoint
  server.on("/", HTTP_GET, []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type");

    String html = "<!DOCTYPE html><html><head>";
    html += "<title>ESP32 Irrigation Control</title>";
    html += "<meta name='viewport' content='width=device-width, initial-scale=1'>";
    html += "<style>";
    html += "body { font-family: Arial; text-align: center; margin: 50px; }";
    html += ".button { padding: 15px 30px; font-size: 18px; margin: 10px; cursor: pointer; }";
    html += ".on { background-color: #4CAF50; color: white; }";
    html += ".off { background-color: #f44336; color: white; }";
    html += ".status { font-size: 20px; margin: 20px; }";
    html += "</style></head><body>";
    html += "<h1>ESP32 Irrigation Control</h1>";
    html += "<div class='status'>Motor Status: <span id='status'>OFF</span></div>";
    html += "<div class='status'>LED Status: <span id='led'>OFF</span></div>";
    html += "<button class='button on' onclick='turnOn()'>Motor ON</button>";
    html += "<button class='button off' onclick='turnOff()'>Motor OFF</button>";
    html += "<script>";
    html += "function turnOn() {";
    html += "fetch('/api/motor/on', {method: 'POST'})";
    html += ".then(response => response.json())";
    html += ".then(data => {";
    html += "document.getElementById('status').innerText = 'ON';";
    html += "document.getElementById('led').innerText = 'BLINKING';";
    html += "});";
    html += "}";
    html += "function turnOff() {";
    html += "fetch('/api/motor/off', {method: 'POST'})";
    html += ".then(response => response.json())";
    html += ".then(data => {";
    html += "document.getElementById('status').innerText = 'OFF';";
    html += "document.getElementById('led').innerText = 'OFF';";
    html += "});";
    html += "}";
    html += "</script></body></html>";

    server.send(200, "text/html", html);
  });

  // Main Motor ON endpoint
  server.on("/api/mainmotor/on", HTTP_POST, []() {
    Serial.println("🌐 HTTP Request: POST /api/mainmotor/on");
    Serial.println("📄 Client IP: " + server.client().remoteIP().toString());
    Serial.println("🔍 User-Agent: " + server.header("User-Agent"));

    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type, Authorization");

    Serial.println("🔧 Main Motor ON request received");
    mainMotorState = true;
    mainMotorOnTime = millis(); // Start 3-second timer

    // Force GPIO 2 HIGH with debugging
    digitalWrite(MAIN_MOTOR_PIN, HIGH);
    delay(10); // Small delay to ensure voltage stabilizes

    // Verify the pin state
    int pinState = digitalRead(MAIN_MOTOR_PIN);
    Serial.println("🔴 Main Motor ON - GPIO " + String(MAIN_MOTOR_PIN) + " set to HIGH");
    Serial.println("📊 GPIO " + String(MAIN_MOTOR_PIN) + " actual state: " + String(pinState == HIGH ? "HIGH (3.3V)" : "LOW (0V)"));

    String response = "{\"status\":\"ok\",\"motor\":\"main\",\"motor_id\":0,\"led\":\"on\",\"duration\":3000}";
    server.send(200, "application/json", response);
  });

  // Main Motor OFF endpoint
  server.on("/api/mainmotor/off", HTTP_POST, []() {
    Serial.println("🌐 HTTP Request: POST /api/mainmotor/off");
    Serial.println("📄 Client IP: " + server.client().remoteIP().toString());

    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type, Authorization");

    mainMotorState = false;
    digitalWrite(MAIN_MOTOR_PIN, LOW); // Immediately turn main motor OFF

    Serial.println("⚫ Main Motor OFF - GPIO " + String(MAIN_MOTOR_PIN) + " OFF");

    String response = "{\"status\":\"ok\",\"motor\":\"main\",\"motor_id\":0,\"led\":\"off\"}";
    server.send(200, "application/json", response);
  });

  // Individual Motor ON endpoint
  server.on("/api/motor/on", HTTP_POST, []() {
    Serial.println("🌐 HTTP Request: POST /api/motor/on");
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type");

    // Get motor_id from query parameter (default to 1 if not provided)
    int motorId = server.arg("motor_id").toInt();
    if (motorId < 1 || motorId > NUM_MOTORS) {
      motorId = 1; // Default to motor 1
    }
    int motorIndex = motorId - 1; // Convert to 0-based index

    motorStates[motorIndex] = true;
    motorOnTimes[motorIndex] = millis(); // Start 3-second timer
    digitalWrite(MOTOR_PINS[motorIndex], HIGH); // Turn motor ON immediately

    Serial.println("🔴 Motor " + String(motorId) + " ON - GPIO " + String(MOTOR_PINS[motorIndex]) + " ON for 3 seconds");

    String response = "{\"status\":\"ok\",\"motor_id\":" + String(motorId) + ",\"motor\":\"on\",\"led\":\"on\",\"duration\":3000}";
    server.send(200, "application/json", response);
  });

  // Motor OFF endpoint
  server.on("/api/motor/off", HTTP_POST, []() {
    Serial.println("🌐 HTTP Request: POST /api/motor/off");
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type");

    // Get motor_id from query parameter (default to 1 if not provided)
    int motorId = server.arg("motor_id").toInt();
    if (motorId < 1 || motorId > NUM_MOTORS) {
      motorId = 1; // Default to motor 1
    }
    int motorIndex = motorId - 1; // Convert to 0-based index

    motorStates[motorIndex] = false;
    digitalWrite(MOTOR_PINS[motorIndex], LOW); // Immediately turn motor OFF

    Serial.println("⚫ Motor " + String(motorId) + " OFF - GPIO " + String(MOTOR_PINS[motorIndex]) + " OFF");

    String response = "{\"status\":\"ok\",\"motor_id\":" + String(motorId) + ",\"motor\":\"off\",\"led\":\"off\"}";
    server.send(200, "application/json", response);
  });

  // Motor status endpoint
  server.on("/api/motor/status", HTTP_GET, []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type");

    // Get motor_id from query parameter (default to 1 if not provided)
    int motorId = server.arg("motor_id").toInt();
    if (motorId < 1 || motorId > NUM_MOTORS) {
      motorId = 1; // Default to motor 1
    }
    int motorIndex = motorId - 1; // Convert to 0-based index

    String motorStatus = motorStates[motorIndex] ? "on" : "off";
    String ledStatus = "off";
    unsigned long timeRemaining = 0;

    if (motorStates[motorIndex]) {
      if (millis() - motorOnTimes[motorIndex] < LED_DURATION) {
        ledStatus = "on";
        timeRemaining = LED_DURATION - (millis() - motorOnTimes[motorIndex]);
      } else {
        ledStatus = "off";
      }
    }

    String response = "{\"motor_id\":" + String(motorId) + ",\"motor\":\"" + motorStatus + "\",\"led\":\"" + ledStatus + "\",\"timeRemaining\":" + timeRemaining + "}";
    server.send(200, "application/json", response);
  });

  // Moisture sensor endpoint
  server.on("/api/moisture", HTTP_GET, []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type");

    // Get sensor_id from query parameter (return all sensors if not provided)
    int sensorId = server.arg("sensor_id").toInt();

    if (sensorId >= 1 && sensorId <= NUM_SENSORS) {
      // Return specific sensor data
      int sensorIndex = sensorId - 1;
      String response = "{\"sensor_id\":" + String(sensorId) + ",\"gpio\":" + String(MOISTURE_SENSOR_PINS[sensorIndex]) + ",\"moisture\":" + String(moisturePercents[sensorIndex]) + ",\"rawValue\":" + String(moistureValues[sensorIndex]) + ",\"unit\":\"%\"}";
      server.send(200, "application/json", response);
    } else {
      // Return all sensors data
      String response = "{\"sensors\":[";
      for (int i = 0; i < NUM_SENSORS; i++) {
        response += "{\"sensor_id\":" + String(i+1) + ",\"gpio\":" + String(MOISTURE_SENSOR_PINS[i]) + ",\"moisture\":" + String(moisturePercents[i]) + ",\"rawValue\":" + String(moistureValues[i]) + "}";
        if (i < NUM_SENSORS - 1) response += ",";
      }
      response += "]}";
      server.send(200, "application/json", response);
    }
  });

  // System status endpoint
  server.on("/api/system/status", HTTP_GET, []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type");

    // Count active motors
    int activeMotors = 0;
    for (int i = 0; i < NUM_MOTORS; i++) {
      if (motorStates[i]) activeMotors++;
    }

    // Calculate average moisture
    int avgMoisture = 0;
    for (int i = 0; i < NUM_SENSORS; i++) {
      avgMoisture += moisturePercents[i];
    }
    avgMoisture = avgMoisture / NUM_SENSORS;

    String json = "{";
    json += "\"status\":\"ok\"";
    json += ",\"mainMotor\":\"" + String(mainMotorState ? "on" : "off") + "\"";
    json += ",\"mainMotorGpio\":" + String(MAIN_MOTOR_PIN);
    json += ",\"totalMotors\":" + String(NUM_MOTORS);
    json += ",\"activeMotors\":" + String(activeMotors);
    json += ",\"totalSensors\":" + String(NUM_SENSORS);
    json += ",\"avgMoisture\":" + String(avgMoisture);
    json += ",\"uptime\":" + String(millis());
    json += ",\"freeHeap\":" + String(ESP.getFreeHeap());
    json += ",\"cpuFreq\":" + String(ESP.getCpuFreqMHz());
    json += "}";
    server.send(200, "application/json", json);
  });

  // Handle CORS preflight requests
  server.on("/api/motor/on", HTTP_OPTIONS, []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type");
    server.send(200, "text/plain", "");
  });

  server.on("/api/motor/off", HTTP_OPTIONS, []() {
    server.sendHeader("Access-Control-Allow-Origin", "*");
    server.sendHeader("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
    server.sendHeader("Access-Control-Allow-Headers", "Content-Type");
    server.send(200, "text/plain", "");
  });
}